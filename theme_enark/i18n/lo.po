#. module: theme_enark
#: model_terms:theme.ir.ui.view,arch:theme_enark.s_text_image
msgid "Building Castle in Cloud"
msgstr "ສ້າງວິມານໃນອາກາດ"

#. module: theme_enark
#: model_terms:theme.ir.ui.view,arch:theme_enark.s_card_offset
msgid "Building the Future of Business"
msgstr "ສ້າງອະນາຄົດຂອງທຸລະກິດ"

#. module: theme_enark
#: model_terms:theme.ir.ui.view,arch:theme_enark.s_carousel_intro
msgid "Building your vision into reality"
msgstr "ສ້າງວິໄສທັດຂອງທ່ານໃຫ້ເປັນຈິງ"

#. module: theme_enark
#: model_terms:theme.ir.ui.view,arch:theme_enark.s_card_offset
msgid ""
"Combine architectural brilliance with business acumen to create spaces that "
"inspire. Our services integrate design and functionality for optimal "
"corporate environments."
msgstr ""
"ປະສົມປະສານຄວາມອັດສະລິຍະດ້ານສະຖາປັດຕະຍະກຳ ເຂົ້າກັບຄວາມສະຫຼາດດ້ານທຸລະກິດ "
"ເພື່ອສ້າງພື້ນທີ່ທີ່ສ້າງແຮງບັນດານໃຈ. ການບໍລິການຂອງພວກເຮົາໄດ້ລວມເອົາການອອກແບບ ແລະ ການໃຊ້ງານ "
"ເພື່ອສະພາບແວດລ້ອມຂອງອົງກອນທີ່ດີທີ່ສຸດ."

#. module: theme_enark
#: model_terms:theme.ir.ui.view,arch:theme_enark.s_cards_grid
msgid "Comprehensive Project Management"
msgstr "ການຄຸ້ມຄອງໂຄງການແບບຄົບວົງຈອນ"

#. module: theme_enark
#: model_terms:theme.ir.ui.view,arch:theme_enark.s_pricelist_boxed
msgid ""
"Comprehensive project management services, including coordination with "
"contractors, scheduling, and quality control throughout the construction "
"process."
msgstr ""
"ການບໍລິການຄຸ້ມຄອງໂຄງການແບບຄົບວົງຈອນ, ລວມທັງການປະສານງານກັບຜູ້ຮັບເໝົາ, ການວາງແຜນກຳນົດເວລາ, "
"ແລະ ການຄວບຄຸມຄຸນນະພາບຕະຫຼອດຂະບວນການກໍ່ສ້າງ."

#. module: theme_enark
#: model_terms:theme.ir.ui.view,arch:theme_enark.s_media_list
msgid "Construction site"
msgstr "ເຂດກໍ່ສ້າງ"

#. module: theme_enark
#: model_terms:theme.ir.ui.view,arch:theme_enark.s_cards_grid
msgid "Crafting Tomorrow's Architectural Icons"
msgstr "ສ້າງສັນສັນຍະລັກທາງສະຖາປັດຕະຍະກຳແຫ່ງອະນາຄົດ"

#. module: theme_enark
#: model_terms:theme.ir.ui.view,arch:theme_enark.s_picture
msgid "Creating places that enhance the human experience."
msgstr "ສ້າງສະຖານທີ່ທີ່ຍົກລະດັບປະສົບການຂອງມະນຸດ."

#. module: theme_enark
#: model_terms:theme.ir.ui.view,arch:theme_enark.s_key_benefits
msgid "Custom Design Solutions"
msgstr "ໂຊລູຊັ່ນການອອກແບບຕາມຄວາມຕ້ອງການ"

#. module: theme_enark
#: model_terms:theme.ir.ui.view,arch:theme_enark.s_pricelist_boxed
msgid "Custom Home Design"
msgstr "ການອອກແບບເຮືອນຕາມຄວາມຕ້ອງການ"

#. module: theme_enark
#: model_terms:theme.ir.ui.view,arch:theme_enark.s_wavy_grid
msgid "Customized Projects"
msgstr "ໂຄງການທີ່ປັບແຕ່ງສະເພາະ"

#. module: theme_enark
#: model_terms:theme.ir.ui.view,arch:theme_enark.s_striped_center_top
