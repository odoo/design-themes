        <attribute name="style" remove="border-radius: 6.4px !important; grid-area: 17 / 1 / 20 / 7;" add="grid-area: 12 / 1 / 15 / 8; --box-border-bottom-left-radius: 96px; --box-border-bottom-right-radius: 16px; --box-border-top-right-radius: 16px; --box-border-top-left-radius: 16px;" separator=";"/>
    </xpath>
    <xpath expr="(//div[hasclass('o_grid_item')])[3]/h2" position="attributes">
        <attribute name="style">text-align: center;</attribute>
    </xpath>
    <xpath expr="(//div[hasclass('o_grid_item')])[3]/p" position="attributes">
        <attribute name="style">text-align: center;</attribute>
    </xpath>
    <xpath expr="((//div[hasclass('o_grid_item')])[3]/p)[2]" position="attributes">
        <attribute name="style">text-align: center;</attribute>
    </xpath>
    <xpath expr="(//div[hasclass('o_grid_item')])[4]" position="attributes">
        <attribute name="class" remove="g-col-lg-6 g-height-10 col-lg-6 justify-content-start" add="g-col-lg-7 col-lg-7 g-height-5 justify-content-end o-shadow-custom border" separator=" "/>
        <attribute name="style" remove="--grid-item-padding-x: 32px; --grid-item-padding-y: 32px; border-radius: 6.4px !important; grid-area: 7 / 1 / 17 / 7;" add="grid-area: 7 / 1 / 12 / 8; --grid-item-padding-y: 48px; --grid-item-padding-x: 48px; --box-border-bottom-left-radius: 16px; --box-border-bottom-right-radius: 16px; --box-border-top-right-radius: 96px; --box-border-top-left-radius: 16px; --box-border-left-width: 4px; --box-border-bottom-width: 4px; --box-border-right-width: 4px; --box-border-top-width: 4px; box-shadow: var(--o-color-5) 0px 0px 0px 2px !important; border-color: var(--o-color-4) !important;" separator=";"/>
    </xpath>
    <xpath expr="(//div[hasclass('o_grid_item')])[5]" position="attributes">
        <attribute name="class" remove="g-col-lg-6 g-height-14 col-lg-6" add="g-col-lg-5 g-height-9 col-lg-5 o-shadow-custom border" separator=" "/>
        <attribute name="style" remove="border-radius: 6.4px !important; grid-area: 6 / 7 / 20 / 13; --grid-item-padding-x: 32px; --grid-item-padding-y: 32px;" add="grid-area: 6 / 8 / 15 / 13; --grid-item-padding-y: 48px; --grid-item-padding-x: 48px; --box-border-bottom-left-radius: 16px; --box-border-bottom-right-radius: 96px; --box-border-top-right-radius: 16px; --box-border-top-left-radius: 96px; --box-border-left-width: 4px; --box-border-bottom-width: 4px; --box-border-right-width: 4px; --box-border-top-width: 4px; box-shadow: var(--o-color-5) 0px 0px 0px 2px !important; border-color: var(--o-color-4) !important;" separator=";"/>
    </xpath>
    <!-- Remove <br/> from the text to apply the correct alignment -->
    <xpath expr="//div[hasclass('o_grid_item')]/p" position="replace">
        <p class="lead">Elevate your living space with furniture that blends modern aesthetics and classic charm, crafted to bring both comfort and style to your home.</p>
    </xpath>
    <xpath expr="(//div[hasclass('o_grid_item')])[4]/p" position="replace">
        <p class="lead">Elevate your living space with furniture that blends modern aesthetics and classic charm, crafted to bring both comfort and style to your home.</p>
    </xpath>
</template>

