        <attribute name="style" add="padding: 4px;" separator=";"/>
    </xpath>
</template>

<!-- ======== STEPS ======== -->
<template id="s_process_steps" inherit_id="website.s_process_steps">
    <xpath expr="//section" position="attributes">
