<!-- ======== IMAGE - TEXT OVERLAP ======== -->
<template id="s_image_text_overlap" inherit_id="website.s_image_text_overlap">
    <xpath expr="//section" position="attributes">
        <attribute name="class" add="o_cc o_cc4" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('o_grid_mode')]" position="attributes">
        <attribute name="data-row-count">7</attribute>
        <attribute name="style">row-gap: 32px;</attribute>
    </xpath>
    <xpath expr="//div[hasclass('o_grid_item')]" position="attributes">
        <attribute name="class" remove="g-height-9" add="g-height-7 rounded o-shadow-custom border" separator=" "/>
        <attribute name="style" remove="grid-area: 1 / 1 / 10 / 8;" add="--grid-item-padding-x: 0px; --box-border-bottom-left-radius: 48px; --box-border-bottom-right-radius: 48px; --box-border-top-right-radius: 48px; --box-border-top-left-radius: 48px; --box-border-left-width: 2px; --box-border-bottom-width: 2px; --box-border-right-width: 2px; --box-border-top-width: 2px; border-color: var(--o-color-4) !important; grid-area: 1 / 1 / 8 / 8;" separator=";"/>
    </xpath>
    <xpath expr="(//div[hasclass('o_grid_item')])[2]" position="attributes">
        <attribute name="class" remove="g-height-7" add="g-height-5" separator=" "/>
        <attribute name="style" remove="grid-area: 2 / 7 / 9 / 13;" add="border-radius: 48px !important; grid-area: 2 / 7 / 7 / 13;" separator=";"/>
