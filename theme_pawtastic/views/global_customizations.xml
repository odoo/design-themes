<!-- ======== DISCOVERY ======== -->
<template id="s_discovery" inherit_id="website.s_discovery">
    <xpath expr="//section" position="attributes">
        <attribute name="class" add="o_cc o_cc2" separator=" "/>
        <attribute name="style">background-color: transparent; background-image: linear-gradient(0deg, var(--o-color-3) 0%, var(--o-color-4) 100%);"</attribute>
        <attribute name="data-oe-shape-data">{'shape':'html_builder/Floats/13','colors':{'c1':'o-color-1','c2':'o-color-1','c5':'o-color-1'},'flip':[],'showOnMobile':false,'shapeAnimationSpeed':'0'}</attribute>
    </xpath>
    <xpath expr="//section/div" position="before">
        <div class="o_we_shape o_html_builder_Floats_13" style="background-image: url('/html_editor/shape/html_builder/Floats/13.svg?c1=o-color-1&amp;c2=o-color-1&amp;c5=o-color-1');"/>
    </xpath>
    <xpath expr="//a[hasclass('btn-primary')]" position="attributes">
        <attribute name="class" add="btn-lg" separator=" "/>
    </xpath>
    <xpath expr="//a[hasclass('btn-secondary')]" position="attributes">
        <attribute name="class" add="btn-lg" separator=" "/>
    </xpath>
</template>

