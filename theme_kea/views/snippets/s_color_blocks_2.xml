<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_color_blocks_2" inherit_id="website.s_color_blocks_2">
        <!-- Box #1 -->
        <xpath expr="//div[hasclass('col-lg-6')]" position="attributes">
            <attribute name="class" add="oe_img_bg o_bg_img_center pt256 pb256" remove="" separator=" " />
            <attribute name="style">background-image: url('/web/image/website.s_color_blocks_1_default_image'); background-position: 50% 0%;</attribute>
        </xpath>
        <!-- Box #1 - Icon -->
        <xpath expr="//div[hasclass('col-lg-6')]//i" position="replace">
        </xpath>  
        <!-- Box #1 - Title -->
        <xpath expr="//div[hasclass('col-lg-6')]//h2" position="replace">
            <h2>Multiplayer</h2>
        </xpath>
        <!-- Box #1 - Text -->
        <xpath expr="//div[hasclass('col-lg-6')]//p" position="replace">
            <p>Conquer leaderboards, crush workouts, create with friends and more. Get lost in a growing library of VR classics and all-new experiences.</p>
        </xpath>                
        <!-- Box #1 - Button -->
        <xpath expr="//div[hasclass('col-lg-6')]//a" position="attributes">
            <attribute name="class" add="btn-secondary" remove="btn-primary" separator=" " />
        </xpath>
        <xpath expr="//div[hasclass('col-lg-6')]//a" position="replace">
            <a href="#" class="btn btn-link text-white mt-2 font-weight-bold">Explore more ></a>
        </xpath>

        <!-- Box #2 -->
        <xpath expr="//div[hasclass('col-lg-6')][2]" position="attributes">
            <attribute name="class" add="oe_img_bg o_bg_img_center pt256 pb256" remove="" separator=" " />
            <attribute name="style">background-image: url('/web/image/website.s_color_blocks_2_default_image'); background-position: 50% 0%;</attribute>
        </xpath>
        <!-- Box #2 - Icon -->
        <xpath expr="//div[hasclass('col-lg-6')][2]//i" position="replace">
        </xpath>  
        <!-- Box #2 - Title -->
        <xpath expr="//div[hasclass('col-lg-6')][2]//h2" position="replace">
            <h2>Freedom</h2>
        </xpath>
        <!-- Box #2 - Text -->
        <xpath expr="//div[hasclass('col-lg-6')][2]//p" position="replace">
            <p>No matter who you are, with a growing library of games and experiences there is no limit to where you can go and what you can do in virtual reality.</p>
        </xpath>
        <!-- Box #2 - Button -->
        <xpath expr="//div[hasclass('col-lg-6')][2]//a" position="attributes">
            <attribute name="class" add="btn-secondary" remove="btn-primary" separator=" " />
        </xpath>
        <xpath expr="//div[hasclass('col-lg-6')][2]//a" position="replace">
            <a href="#" class="btn btn-link text-white mt-2 font-weight-bold">Explore more ></a>
        </xpath>   
    </template>
</odoo>
