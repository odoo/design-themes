<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_three_columns" inherit_id="website.s_three_columns">
        <!-- Section -->
        <xpath expr="//section" position="attributes">
            <attribute name="class" add="o_cc3" remove="o_cc2" separator=" "/>
        </xpath>
        <!-- Column 1 -->
        <xpath expr="//div[hasclass('card')]" position="attributes">
            <attribute name="class" add="border bg-transparent" remove="bg-white" separator=" "/>
            <attribute name="style" add="border-width: 0px !important;" separator=" "/>
        </xpath>
        <xpath expr="//div[hasclass('card')]/img" position="attributes">
            <attribute name="class" add="rounded-circle mb-2 img-thumbnail" separator=" "/>
            <attribute name="style" add="box-shadow: rgb(0 0 0 / 10%) 0px 20px 10px -5px, rgb(0 0 0 / 4%) 0px 10px 10px -5px !important;" separator=" "/>
        </xpath>
        <xpath expr="//div[hasclass('card-body')]" position="replace">
            <div class="card-body text-white text-center" style="background-color:transparent !important">
                <h3 class="card-title">Gaming</h3>
                <p class="card-text">VR takes immersive gaming to another level. From deep environmental interactions to puzzle solving.</p>
            </div>
        </xpath>
        <!-- Column 2 -->
        <xpath expr="(//div[hasclass('card')])[2]" position="attributes">
            <attribute name="class" add="border bg-transparent" remove="bg-white" separator=" "/>
            <attribute name="style" add="border-width: 0px !important;" separator=" "/>
        </xpath>
        <xpath expr="(//div[hasclass('card')]/img)[2]" position="attributes">
            <attribute name="class" add="rounded-circle mb-2 img-thumbnail" separator=" "/>
            <attribute name="style" add="box-shadow: rgb(0 0 0 / 10%) 0px 20px 10px -5px, rgb(0 0 0 / 4%) 0px 10px 10px -5px !important;" separator=" "/>
        </xpath>
        <xpath expr="(//div[hasclass('card-body')])[2]" position="replace">
            <div class="card-body text-white text-center" style="background-color:transparent !important">
                <h3 class="card-title">Design</h3>
                <p class="card-text">From design concept to the showroom, create and manage workflows with better collaboration.</p>
            </div>
        </xpath>
        <!-- Column 3 -->
        <xpath expr="(//div[hasclass('card')])[3]" position="attributes">
            <attribute name="class" add="border bg-transparent" remove="bg-white" separator=" "/>
            <attribute name="style" add="border-width: 0px !important;" separator=" "/>
        </xpath>
        <xpath expr="(//div[hasclass('card')]/img)[3]" position="attributes">
            <attribute name="class" add="rounded-circle mb-2 img-thumbnail" separator=" "/>
            <attribute name="style" add="box-shadow:rgb(0 0 0 / 10%) 0px 20px 10px -5px, rgb(0 0 0 / 4%) 0px 10px 10px -5px !important;" separator=" "/>
        </xpath>
        <xpath expr="(//div[hasclass('card-body')])[3]" position="replace">
            <div class="card-body text-white text-center" style="background-color:transparent !important">
                <h3 class="card-title">Training</h3>
                <p class="card-text">From high-risk safety simulations and maintenance procedures to soft skills like public speaking.</p>
            </div>
        </xpath>
    </template>
</odoo>
