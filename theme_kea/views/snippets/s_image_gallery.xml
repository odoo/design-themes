<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_images_wall" inherit_id="website.s_images_wall">
        <!-- Section -->
        <xpath expr="//section" position="attributes">
            <attribute name="class" add="pt96 pb96" remove="pt24 pb24" separator=" "/>
        </xpath>
        <!-- Replace images -->
        <xpath expr="//div[hasclass('o_masonry_col')][2]//img" position="replace">
            <img class="img img-fluid d-block" src="/web/image/website.library_image_03" data-index="4" data-name="Image"/>
        </xpath>
        <xpath expr="//div[hasclass('o_masonry_col')][2]//img[2]" position="replace">
            <img class="img img-fluid d-block" src="/web/image/website.library_image_10" data-index="5" data-name="Image"/>
        </xpath>
        <xpath expr="//div[hasclass('o_masonry_col')][3]//img[last()]" position="replace">
            <img class="img img-fluid d-block" src="/web/image/website.library_image_05" data-index="3" data-name="Image"/>
        </xpath>
        <xpath expr="//div[hasclass('o_masonry_col')][2]//img[last()]" position="after">
            <img class="img img-fluid d-block" src="/web/image/website.library_image_14" data-index="6" data-name="Image"/>
        </xpath>
    </template>
</odoo>
