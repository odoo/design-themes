#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_features
msgid "<b>360-degree vision</b>"
msgstr "<b>ມຸມມອງ 360 ອົງສາ</b>"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_features
msgid "<b>Built in mic</b>"
msgstr "<b>ມີໄມໂຄຣໂຟນໃນຕົວ</b>"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_features
msgid "<b>Stunning visuals</b>"
msgstr "<b>ພາບທີ່ສວຍງາມໜ້າຕື່ນຕາ</b>"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_image_text
msgid ""
"<font style=\"background-image: linear-gradient(135deg, var(--o-color-1) 0%,"
" var(--o-color-2) 100%);\" class=\"text-gradient\">Enter in a new "
"world</font>"
msgstr ""
"<font style=\"background-image: linear-gradient(135deg, var(--o-color-1) 0%, "
"var(--o-color-2) 100%);\" class=\"text-gradient\">ກ້າວເຂົ້າສູ່ໂລກໃໝ່</font>"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_text_image
msgid ""
"<font style=\"background-image: linear-gradient(135deg, var(--o-color-1) 0%,"
" var(--o-color-2) 100%);\" class=\"text-gradient\">Full immersion</font>"
msgstr ""
"<font style=\"background-image: linear-gradient(135deg, var(--o-color-1) 0%, "
"var(--o-color-2) 100%);\" class=\"text-gradient\">ເຂົ້າເຖິງປະສົບການທີ່ສົມຈິງ</font>"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_features
msgid "A small explanation of this great feature, in clear words."
msgstr "ຄຳອະທິບາຍສັ້ນໆ ກ່ຽວກັບຄຸນສົມບັດທີ່ດີເດັ່ນນີ້ ດ້ວຍຖ້ອຍຄຳທີ່ຊັດເຈນ."

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_media_list
msgid "Comfort &amp; Ease"
msgstr "ຄວາມສະດວກສະບາຍ ແລະ ງ່າຍດາຍ"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_color_blocks_2
msgid ""
"Conquer leaderboards, crush workouts, create with friends and more. Get lost"
" in a growing library of VR classics and all-new experiences."
msgstr ""
"ພິຊິດລີດເດີບອດ, ອອກກຳລັງກາຍຢ່າງເຕັມທີ່, ສ້າງສັນຮ່ວມກັບໝູ່ເພື່ອນ ແລະ ອື່ນໆ. ເພີດເພີນໄປກັບຄັງເກມ VR ຄລ"
"າສສິກ ແລະ ປະສົບການໃໝ່ໆທີ່ເພີ່ມຂຶ້ນເລື້ອຍໆ."

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_three_columns
msgid "Design"
msgstr "ການອອກແບບ"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_numbers
msgid "Different lenses"
msgstr "ເລນທີ່ແຕກຕ່າງກັນ"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_cover
msgid "Discover more"
msgstr "ຄົ້ນຫາເພີ່ມເຕີມ"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_picture
msgid "Experience a new world"
msgstr "ສຳຜັດກັບໂລກໃໝ່"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_media_list
msgid "Fitting design"
msgstr "ການອອກແບບທີ່ພໍດີ"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_color_blocks_2
msgid "Freedom"
msgstr "ອິດສະລະພາບ"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_three_columns
msgid ""
"From design concept to the showroom, create and manage workflows with better"
" collaboration."
msgstr ""
"ຕັ້ງແຕ່ແນວຄວາມຄິດການອອກແບບຈົນເຖິງຫ້ອງສະແດງ, ສ້າງ ແລະ ຈັດການຂັ້ນຕອນການເຮັດວຽກດ້ວຍການຮ່ວມມືທີ່ດີຂຶ້"
"ນ."

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_three_columns
msgid ""
"From high-risk safety simulations and maintenance procedures to soft skills "
"like public speaking."
msgstr ""
"ຕັ້ງແຕ່ການຈຳລອງຄວາມປອດໄພທີ່ມີຄວາມສ່ຽງສູງ ແລະ ຂັ້ນຕອນການບຳລຸງຮັກສາ ຈົນເຖິງທັກສະ Soft Skills ເ"
"ຊັ່ນ: ການເວົ້າໃນທີ່ສາທາລະນະ."

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_three_columns
msgid "Gaming"
msgstr "ການຫຼິ້ນເກມ"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_color_blocks_2
msgid "Multiplayer"
msgstr "ຜູ້ຫຼິ້ນຫຼາຍຄົນ"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_media_list
msgid "Natural control"
msgstr "ການຄວບຄຸມແບບທຳມະຊາດ"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_numbers
msgid "New games every week"
msgstr ""

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_color_blocks_2
msgid ""
"No matter who you are, with a growing library of games and experiences there"
" is no limit to where you can go and what you can do in virtual reality."
msgstr ""
"ບໍ່ວ່າທ່ານຈະແມ່ນໃຜ, ດ້ວຍຄັງເກມ ແລະ ປະສົບການທີ່ເພີ່ມຂຶ້ນເລື້ອຍໆ ບໍ່ມີຂີດຈຳກັດວ່າທ່ານຈະໄປໃສ ຫຼື ເຮັດຫຍັງໄດ້"
"ແດ່ໃນໂລກສະເໝືອນຈິງ."

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_numbers
msgid "Number of controllers"
msgstr "ຈຳນວນຕົວຄວບຄຸມ"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_picture
msgid ""
"Put yourself at the center of an extraordinary gaming universe with "
"exclusive games."
msgstr ""
"ພາຕົວທ່ານເຂົ້າສູ່ໃຈກາງຂອງຈັກກະວານການຫຼິ້ນເກມທີ່ພິເສດ ດ້ວຍເກມສຸດພິເສດສະເພາະ."

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_numbers
msgid "Storage capacity (GB)"
msgstr "ຄວາມຈຸຂອງໜ່ວຍຄວາມຈຳ (GB)"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_features
msgid "Tell what's the value for the customer for this feature."
msgstr "ບອກເຖິງຄຸນຄ່າທີ່ລູກຄ້າຈະໄດ້ຮັບຈາກຄຸນສົມບັດນີ້."

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_cover
msgid "The Revolution <br/> in Virtual Reality"
msgstr "ການປະຕິວັດ <br/> ໃນໂລກສະເໝືອນຈິງ"

#. module: theme_kea
#: model:ir.model,name:theme_kea.model_theme_utils
msgid "Theme Utils"
msgstr "ເຄື່ອງມືຊ່ວຍຈັດການທີມ (Theme Utils)"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_three_columns
msgid "Training"
msgstr "ການຝຶກອົບຮົມ"

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_media_list
msgid ""
"Use this snippet to build various types of components that feature a left- "
"or right-aligned image alongside textual content. Duplicate the element to "
"create a list that fits your needs."
msgstr ""
"ໃຊ້ Snippet ນີ້ເພື່ອສ້າງອົງປະກອບຕ່າງໆ ທີ່ມີຮູບພາບຈັດວາງຢູ່ເບື້ອງຊ້າຍ ຫຼື ຂວາ ຄຽງຄູ່ກັບເນື້ອຫາຂໍ້ຄວາມ. ສາ"
"ມາດສ້າງອົງປະກອບເພີ່ມເພື່ອໃຫ້ໄດ້ລາຍການທີ່ກົງກັບຄວາມຕ້ອງການຂອງທ່ານ."

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_three_columns
msgid ""
"VR takes immersive gaming to another level. From deep environmental "
"interactions to puzzle solving."
msgstr ""
"VR ຍົກລະດັບການຫຼິ້ນເກມທີ່ສົມຈິງໄປສູ່ອີກຂັ້ນ. ຕັ້ງແຕ່ການໂຕ້ຕອບກັບສະພາບແວດລ້ອມທີ່ເລິກເຊິ່ງ ຈົນເຖິງການແກ້ໄຂປິ"
"ດສະໜາ."

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_picture
msgid ""
"Watch as a living game world comes alive all around you, with a seamless "
"field of view wherever you look."
msgstr ""
"ເບິ່ງໂລກຂອງເກມທີ່ມີຊີວິດຊີວາມາປະກົດຢູ່ອ້ອມຕົວທ່ານ ດ້ວຍມຸມມອງທີ່ຕໍ່ເນື່ອງບໍ່ວ່າທ່ານຈະຫຼຽວໄປທາງໃດ."

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_media_list
msgid ""
"We only use original parts or parts of equivalent quality. ​We make sure you"
" get the best quality available on the market at the best price. All our "
"interventions are guaranteed for a period of one year."
msgstr ""
"ພວກເຮົາໃຊ້ແຕ່ອາໄຫຼ່ແທ້ ຫຼື ອາໄຫຼ່ທີ່ມີຄຸນນະພາບທຽບເທົ່າເທົ່ານັ້ນ. ພວກເຮົາຮັບປະກັນວ່າທ່ານຈະໄດ້ຮັບຄຸນນະພາບທີ່ດີ"
"ທີ່ສຸດໃນຕະຫຼາດໃນລາຄາທີ່ຄຸ້ມຄ່າທີ່ສຸດ. ການບໍລິການທັງໝົດຂອງພວກເຮົາແມ່ນມີການຮັບປະກັນເປັນເວລາໜຶ່ງປີ."

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_text_image
msgid ""
"Write one or two paragraphs describing your product or services. To be "
"successful your content needs to be useful to your readers."
msgstr ""
"ຂຽນໜຶ່ງ ຫຼື ສອງຫຍໍ້ໜ້າເພື່ອບັນຍາຍສິນຄ້າ ຫຼື ບໍລິການຂອງທ່ານ. ເພື່ອໃຫ້ປະສົບຜົນສຳເລັດ ເນື້ອຫາຂອງທ່ານຕ້ອງມີປະ"
"ໂຫຍດຕໍ່ຜູ້ອ່ານ."

#. module: theme_kea
#: model_terms:theme.ir.ui.view,arch:theme_kea.s_features
msgid "Write what the customer would like to know, not what you want to show."
msgstr "ຂຽນສິ່ງທີ່ລູກຄ້າຢາກຮູ້, ບໍ່ແມ່ນແຕ່ສິ່ງທີ່ທ່ານຢາກຈະສະແດງ."
