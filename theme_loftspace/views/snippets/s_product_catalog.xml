<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_product_catalog" inherit_id="website.s_product_catalog">
        <!-- Section -->
        <xpath expr="//section" position="attributes">
            <attribute name="class" add="o_cc3 pt112 pb112" remove="pt48 pb32" separator=" "/>
            <attribute name="data-oe-shape-data">{"shape":"web_editor/Floats/09","flip":[]}</attribute>
        </xpath>
        <!-- Filter & shape -->
        <xpath expr="//div[hasclass('container')]" position="before">
            <div class="o_we_bg_filter" style="background-color: rgba(50, 39, 59, 0.85) !important;"/>
            <div class="o_we_shape o_web_editor_Floats_09"/>
        </xpath>
        <!-- Title & subtitles -->
        <xpath expr="//h2" position="replace">
            <h2>Discover our options</h2>
        </xpath>
        <xpath expr="//h3" position="replace">
            <h3>Wood types</h3>
        </xpath>
        <xpath expr="(//h3)[2]" position="replace">
            <h3>Extra materials</h3>
        </xpath>
        <!-- Description -->
        <xpath expr="//div[hasclass('container')]//p" position="replace">
            <p>Add a description.</p>
        </xpath>
        <!-- List names left column -->
        <xpath expr="//ul/t/t" position="replace">
            <t t-set="name">Oak wood</t>
        </xpath>
        <xpath expr="//ul/t[2]/t" position="replace">
            <t t-set="name">Pine wood</t>
        </xpath>
        <xpath expr="//ul/t[3]/t" position="replace">
            <t t-set="name">Beech wood</t>
        </xpath>
        <!-- List names right column -->
        <xpath expr="(//ul)[2]/t/t" position="replace">
            <t t-set="name">Steel</t>
        </xpath>
        <xpath expr="(//ul)[2]/t[2]/t" position="replace">
            <t t-set="name">Copper</t>
        </xpath>
        <xpath expr="(//ul)[2]/t[3]/t" position="replace">
            <t t-set="name">Marble</t>
        </xpath>
    </template>
</odoo>
