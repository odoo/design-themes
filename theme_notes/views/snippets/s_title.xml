<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_title" inherit_id="website.s_title">
        <!-- Section -->
        <xpath expr="//section" position="attributes">
            <attribute name="class" add="o_cc2" separator=" "/>
        </xpath>
        <!-- Title -->
        <xpath expr="//h1" position="replace">
            <h1 style="text-align: center;"><span style="font-size: 62px;">Our special Guests</span></h1>
        </xpath>
    </template>
</odoo>
