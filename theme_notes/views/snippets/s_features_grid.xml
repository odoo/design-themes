<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_features_grid" inherit_id="website.s_features_grid">
        <!-- Section -->
        <xpath expr="//section" position="attributes">
            <attribute name="class" add="o_cc5 pb72 pt96" remove="pt48 pb24" separator=" "/>
            <attribute name="data-oe-shape-data">{"shape":"web_editor/Wavy/13_001","flip":[]}</attribute>
        </xpath>
        <!-- Left Title -->
        <xpath expr="//h2" position="replace">
            <h2>With the VIP Pass</h2>
        </xpath>
        <!-- Left Subtitle -->
        <xpath expr="//h5" position="replace">
            <h5><span class="text-o-color-1">Add a great slogan.</span></h5>
        </xpath>
        <!-- Right Title -->
        <xpath expr="(//h2)[2]" position="replace">
            <h2>With the Premium Pass</h2>
        </xpath>
        <!-- Right Subtitle -->
        <xpath expr="(//h5)[2]" position="replace">
            <h5><span class="text-o-color-2">Add a great slogan.</span></h5>
        </xpath>
        <!-- Item #1 -->
        <xpath expr="//i" position="attributes">
            <attribute name="class" add="fa-ticket" remove="fa-font-awesome" separator=" "/>
        </xpath>
        <xpath expr="//h4" position="replace">
            <h4>Book your tickets in advance</h4>
        </xpath>
        <!-- Item #2 -->
        <xpath expr="(//i)[2]" position="attributes">
            <attribute name="class" add="fa-automobile" remove="fa-files-o" separator=" "/>
        </xpath>
        <xpath expr="(//h4)[2]" position="replace">
            <h4>Free parking</h4>
        </xpath>
        <!-- Item #3 -->
        <xpath expr="(//i)[3]" position="attributes">
            <attribute name="class" add="fa-glass" remove="fa-trash" separator=" "/>
        </xpath>
        <xpath expr="(//h4)[3]" position="replace">
            <h4>VIP Area</h4>
        </xpath>
        <!-- Item #4 -->
        <xpath expr="(//i)[4]" position="attributes">
            <attribute name="class" add="rounded-circle fa-key" remove="rounded fa-magic" separator=" "/>
        </xpath>
        <xpath expr="(//h4)[4]" position="replace">
            <h4>Access to Backstage</h4>
        </xpath>
        <!-- Item #5 -->
        <xpath expr="(//i)[5]" position="attributes">
            <attribute name="class" add="rounded-circle fa-money" remove="rounded fa-eyedropper" separator=" "/>
        </xpath>
        <xpath expr="(//h4)[5]" position="replace">
            <h4>Unique discounts</h4>
        </xpath>
        <!-- Item #6 -->
        <xpath expr="(//i)[6]" position="attributes">
            <attribute name="class" add="rounded-circle fa-gift" remove="rounded fa-picture-o" separator=" "/>
        </xpath>
        <xpath expr="(//h4)[6]" position="replace">
            <h4>Get your festival T-Shirt</h4>
        </xpath>
    </template>
</odoo>
