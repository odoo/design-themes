<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_numbers" inherit_id="website.s_numbers">
        <!-- Section -->
        <xpath expr="//section" position="attributes">
            <attribute name="class" add="pt0 pb0" remove="pt24 pb24 o_cc o_cc2" separator=" "/>
        </xpath>
        <!-- Container -->
        <xpath expr="//div[hasclass('container')]" position="attributes">
            <attribute name="class" add="container-fluid" remove="container" separator=" "/>
        </xpath>
        <!-- Column #1 -->
        <xpath expr="//div[hasclass('col-lg-3')]" position="attributes">
            <attribute name="class" add="pt104 pb104 o_cc5" remove="pt24 pb24" separator=" "/>
        </xpath>
        <!-- Column #1 - Number -->
        <xpath expr="//span[hasclass('s_number')]" position="attributes">
            <attribute name="style">font-weight: bolder;</attribute>
        </xpath>
        <!-- Column #1 - Text -->
        <xpath expr="//h6" position="replace">
            <h6>Editions through the Europe</h6>
        </xpath>
        <!-- Column #2 -->
        <xpath expr="(//div[hasclass('col-lg-3')])[2]" position="attributes">
            <attribute name="class" add="pt104 pb104 o_cc2" remove="pt24 pb24" separator=" "/>
        </xpath>
        <!-- Column #2 - Number -->
        <xpath expr="(//span[hasclass('s_number')])[2]" position="attributes">
            <attribute name="style">font-weight: bolder;</attribute>
        </xpath>
        <!-- Column #2 - Text -->
        <xpath expr="(//h6)[2]" position="replace">
            <h6>Artists from around the world</h6>
        </xpath>
        <!-- Column #3 -->
        <xpath expr="(//div[hasclass('col-lg-3')])[3]" position="attributes">
            <attribute name="class" add="pt104 pb104 o_cc3" remove="pt24 pb24" separator=" "/>
        </xpath>
        <!-- Column #3 - Number -->
        <xpath expr="(//span[hasclass('s_number')])[3]" position="attributes">
            <attribute name="style">font-weight: bolder;</attribute>
        </xpath>
        <!-- Column #3 - Text -->
        <xpath expr="(//h6)[3]" position="replace">
            <h6>Scenes outdoor &amp; indoor</h6>
        </xpath>
        <!-- Column #4 -->
        <xpath expr="(//div[hasclass('col-lg-3')])[4]" position="attributes">
            <attribute name="class" add="pt104 pb104 o_cc4" remove="pt24 pb24" separator=" "/>
        </xpath>
        <!-- Column #4 - Number -->
        <xpath expr="(//span[hasclass('s_number')])[4]" position="attributes">
            <attribute name="style">font-weight: bolder;</attribute>
        </xpath>
        <!-- Column #4 - Text -->
        <xpath expr="(//h6)[4]" position="replace">
            <h6>Loyal partners</h6>
        </xpath>
    </template>
</odoo>
