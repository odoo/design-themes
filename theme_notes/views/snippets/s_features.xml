<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_features" inherit_id="website.s_features">
        <!-- Icon #1 -->
        <xpath expr="//i" position="attributes">
            <attribute name="class" add="rounded-circle fa-leaf" remove="rounded fa-gear" separator=" "/>
        </xpath>
        <!-- Icon #2 -->
        <xpath expr="(//i)[2]" position="attributes">
            <attribute name="class" add="rounded-circle fa-tint" remove="rounded fa-photo" separator=" "/>
        </xpath>
        <!-- Icon #3 -->
        <xpath expr="(//i)[3]" position="attributes">
            <attribute name="class" add="rounded-circle fa-home" remove="rounded fa-leaf" separator=" "/>
        </xpath>
        <!-- Title #1 -->
        <xpath expr="//h3" position="replace">
            <h3>Green Energy</h3>
        </xpath>
        <!-- Title #2 -->
        <xpath expr="(//h3)[2]" position="replace">
            <h3>Water</h3>
        </xpath>
        <!-- Title #3 -->
        <xpath expr="(//h3)[3]" position="replace">
            <h3>Green Camping</h3>
        </xpath>
    </template>
</odoo>
