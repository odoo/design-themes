<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_product_catalog" inherit_id="website.s_product_catalog">
        <!-- Section -->
        <xpath expr="//section" position="attributes">
            <attribute name="class" add="o_cc5 pb160 pt160 parallax s_parallax_is_fixed s_parallax_no_overflow_hidden o_full_screen_height" remove="pb32 pt48" separator=" "/>
            <attribute name="data-scroll-background-ratio">1</attribute>
            <attribute name="data-oe-shape-data">{"shape":"web_editor/Wavy/10","flip":[]}</attribute>
        </xpath>
        <!-- Shape & Background image -->
        <xpath expr="//section/*" position="before">
            <span class="s_parallax_bg oe_img_bg o_bg_img_center" style="background-image: url('/web/image/website.s_product_catalog_default_image');"/>
            <div class="o_we_shape o_web_editor_Wavy_10"/>
        </xpath>
        <!-- Title & subtitles -->
        <xpath expr="//h2" position="replace">
            <h2 style="text-align: center;"><span style="font-size: 48px;">Upcoming events</span></h2>
        </xpath>
        <xpath expr="(//h3)" position="replace">
            <h3>Brussels edition</h3>
        </xpath>
        <xpath expr="(//h3)[2]" position="replace">
            <h3>Paris edition</h3>
        </xpath>
        <!-- Description -->
        <xpath expr="//div[hasclass('container')]//p" position="replace">
            <p style="text-align: center;">Get your ticket now</p>
        </xpath>
        <!-- Left column : names -->
        <xpath expr="//ul/t/t" position="replace">
            <t t-set="name">Regular ticket</t>
        </xpath>
        <xpath expr="//ul/t[2]/t" position="replace">
            <t t-set="name">Regular ticket + hotel</t>
        </xpath>
        <xpath expr="//ul/t[3]/t" position="replace">
            <t t-set="name">VIP ticket</t>
        </xpath>
        <!-- Left column : prices -->
        <xpath expr="//ul/t/t[2]" position="replace">
            <t t-set="price">$19.00</t>
        </xpath>
        <xpath expr="//ul/t[2]/t[2]" position="replace">
            <t t-set="price">$59.00</t>
        </xpath>
        <xpath expr="//ul/t[3]/t[2]" position="replace">
            <t t-set="price">$109.50</t>
        </xpath>
        <!-- Right column : names -->
        <xpath expr="(//ul)[2]/t/t" position="replace">
            <t t-set="name">Regular ticket</t>
        </xpath>
        <xpath expr="(//ul)[2]/t[2]/t" position="replace">
            <t t-set="name">Regular ticket + hotel</t>
        </xpath>
        <xpath expr="(//ul)[2]/t[3]/t" position="replace">
            <t t-set="name">VIP ticket</t>
        </xpath>
        <!-- Right column : prices -->
        <xpath expr="(//ul)[2]//t[2]" position="replace">
            <t t-set="price">$25.00</t>
        </xpath>
        <xpath expr="(//ul)[2]/t[2]/t[2]" position="replace">
            <t t-set="price">$65.00</t>
        </xpath>
        <xpath expr="(//ul)[2]/t[3]/t[2]" position="replace">
            <t t-set="price">$115.50</t>
        </xpath>
    </template>
</odoo>
