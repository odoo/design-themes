<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_color_blocks_2" inherit_id="website.s_color_blocks_2">
        <!-- Container -->
        <xpath expr="//div[hasclass('container-fluid')]" position="attributes">
            <attribute name="class" add="container" remove="container-fluid" separator=" "/>
        </xpath>
        <!-- Column #1 -->
        <xpath expr="//div[hasclass('col-lg-6')]" position="attributes">
            <attribute name="class" remove="o_cc3" separator=" "/>
        </xpath>
        <!-- Column #1 - Icon -->
        <xpath expr="//div[hasclass('col-lg-6')]//i" position="attributes">
            <attribute name="class" add="fa-map-o" remove="fa-shield" separator=" "/>
        </xpath>
        <!-- Column #1 - Title -->
        <xpath expr="//div[hasclass('col-lg-6')]//h2" position="replace">
            <h2>How to get there?</h2>
            <p><br/></p>
        </xpath>
        <!-- Column #2 -->
        <xpath expr="(//div[hasclass('col-lg-6')])[2]" position="attributes">
            <attribute name="class" remove="o_cc5" separator=" "/>
        </xpath>
        <!-- Column #2 - Icon -->
        <xpath expr="(//div[hasclass('col-lg-6')])[2]//i" position="attributes">
            <attribute name="class" add="fa-file-text-o" remove="fa-cube" separator=" "/>
        </xpath>
        <!-- Column #1 - Title -->
        <xpath expr="(//div[hasclass('col-lg-6')])[2]//h2" position="replace">
            <h2>Rules &amp; Regulations</h2>
            <p><br/></p>
        </xpath>
    </template>
</odoo>
