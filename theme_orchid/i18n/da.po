#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_cards_grid
msgid "Creativity Like a Wildflower"
msgstr "Kreativitet som en vildblomst"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_benefits
msgid "Custom Floral Arrangements"
