#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_images
msgid "Discover Our Most Loved Arrangements"
msgstr "Se vores bedste blomsterarrangementer"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_shape_image
msgid ""
"Discover our exquisite floral arrangements for any occasion. From vibrant "
"bouquets to elegant centerpieces, we craft each design with care, using "
"fresh, beautiful flowers to brighten your day and celebrate life's moments."
msgstr ""
"Se vores udsøgte blomsterarrangementer til enhver lejlighed. Fra farverige "
"buketter til elegante borddekorationer – vi udfører hvert eneste design med "
"omhu og bruger friske, smukke blomster for at gøre din dag endnu smukkere og "
"fejre livets øjeblikke."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_intro_pill
msgid "Discover our<br/>latest arrivals"
msgstr "Se vores<br/>nyeste varer"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_striped_top
msgid "Discover the Orchid concept"
msgstr "Se Orchid-konceptet"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_unveil
msgid "Discover the beauty and grace of flowers with our exquisite collection."
msgstr "Oplev blomsternes skønhed og ynde med vores udsøgte kollektion."

#. module: theme_orchid
#: model:ir.model.fields,field_description:theme_orchid.field_theme_utils__display_name
msgid "Display Name"
