#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_images
msgid ""
"A delicate blend of soft pink roses and baby's breath, perfect for "
"expressing love and gratitude."
msgstr ""
"Jemná kombinace světle růžových růží a gypsophily, ideální pro vyjádření "
"lásky a vděčnosti."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_company_team_basic
msgid "Aline Turner, Bouquet Designer"
msgstr "Aline Turner, Návrhářka kytic"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_company_team_basic
msgid "Aline is the mastermind behind our bespoke floral arrangements."
msgstr "Aline je tvůrcem našich květinových aranžmá na míru."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_kickoff
msgid "Bloom with Joy:"
msgstr "Rozkveťte s radostí:"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_images
msgid "Blushing Harmony"
msgstr "Červenající se harmonie"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_image_text_overlap
msgid ""
"Brighten any corner of the globe with our express 24-hour worldwide flower "
"delivery service."
msgstr ""
"Rozjasněte jakýkoli kout světa díky naší expresní 24hodinové službě "
"doručování květin po celém světě."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_freegrid
msgid "Bringing the Beauty of Nature to Your Space"
msgstr "Vnášíme krásu přírody do vašeho interiéru"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_images
msgid "Celebrate with Our Best-Selling Bouquets, perfect for every occasion."
msgstr ""
"Oslavte s našimi nejprodávanějšími kyticemi, které se hodí pro každou "
"příležitost."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_images
msgid "Discover Our Most Loved Arrangements"
msgstr "Objevte naše nejoblíbenější aranžmá"

#. module: theme_orchid
#: model:ir.model.fields,field_description:theme_orchid.field_theme_utils__display_name
msgid "Display Name"
msgstr "Zobrazovací název"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_images
msgid "Elegant Simplicity"
msgstr "Elegantní prostota"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_freegrid
msgid ""
"Enhance your surroundings with our exquisite floral arrangements and garden "
"designs. We offer a variety of options that bring the serenity and beauty of "
"nature into your home or workspace."
msgstr ""
"Zkrášlete své okolí našimi nádhernými květinovými aranžmá a zahradními "
"návrhy. Nabízíme celou řadu možností, které vnesou do vašeho domova nebo "
"pracovního prostoru klid a krásu přírody."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_freegrid
msgid "Explore Our Gardens"
msgstr "Prohlédněte si naše zahrady"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_title
msgid ""
"Explore our handcrafted floral arrangements, each meticulously designed to "
"convey beauty, elegance, and a touch of nature's artistry."
msgstr ""
"Prohlédněte si naše ručně vyráběné květinové aranžmá, každé z nich pečlivě "
"navržené tak, aby vyjadřovalo krásu, eleganci a dotek umění přírody."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_kickoff
msgid "Fresh Flowers Delivered to Your Doorstep!"
msgstr "Čerstvé květiny doručené až k vašim dveřím!"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_image_text_overlap
msgid "Global 24-Hour Flower Delivery"
msgstr "Celosvětová 24hodinová doručovací služba květin"

#. module: theme_orchid
#: model:ir.model.fields,field_description:theme_orchid.field_theme_utils__id
msgid "ID"
msgstr "ID"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_company_team_basic
msgid "Iris Joe, Customer Relations"
msgstr "Iris Joe, vztahy se zákazníky"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_company_team_basic
msgid "Iris ensures that each customer has a delightful experience."
msgstr "Iris zajišťuje, aby každý zákazník měl příjemný zážitek."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_images
msgid ""
"Light pink blossoms with golden leaves, bringing a touch of springtime charm "
"to any space."
msgstr ""
"Světle růžové květy se zlatými listy, které dodají každému prostoru nádech "
"jarního kouzla."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_company_team_basic
msgid "Meet the Team"
msgstr "Seznamte se s týmem"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_company_team_basic
msgid "Mich Stark, Operations Manager"
msgstr "Mich Stark, manažer operací"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_company_team_basic
msgid "Mich makes sure everything runs smoothly."
msgstr "Mich zajišťuje, aby vše proběhlo hladce."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_images
msgid ""
"Minimalist white florals in a sleek vase, embodying sophistication and grace."
msgstr ""
"Minimalistické bílé květiny v elegantní váze, které ztělesňují "
"sofistikovanost a eleganci."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_title
msgid "Our Creations"
msgstr "Naše výtvory"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_images
msgid "Petal Poetry"
msgstr "Poezie plátků"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_images
msgid "Sunset Serenade"
msgstr "Sluneční serenáda"

#. module: theme_orchid
#: model:ir.model,name:theme_orchid.model_theme_utils
msgid "Theme Utils"
msgstr "Utils šablony"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_company_team_basic
msgid "Tony Fred, Floral Director"
msgstr "Tony Fred, květinový ředitel"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_company_team_basic
msgid "Tony leads the creative vision for the shop."
msgstr "Tony vede kreativní vizi obchodu."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_images
msgid ""
"Vibrant hues of orange and red capture the warmth and beauty of a summer "
"evening."
msgstr ""
"Zářivé odstíny oranžové a červené zachycují teplo a krásu letního večera."
