#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_text_image
msgid ""
"<br/>\n"
"        Deliver flowers to live up to your dedication for your loved ones."
msgstr ""
"<br/>\n"
"        ສົ່ງມອບດອກໄມ້ ເພື່ອສະແດງເຖິງຄວາມຮັກຄວາມຜູກພັນຂອງທ່ານ ທີ່ມີຕໍ່ຄົນທີ່ທ່ານຮັກ."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_empowerment
msgid ""
"<br/>Creating vibrant, handcrafted bouquets to celebrate every "
"occasion.<br/><br/>"
msgstr ""
"<br/>ສ້າງສັນຊໍ່ດອກໄມ້ທີ່ສົດໃສ ດ້ວຍການຈັດແບບປານີດ ເພື່ອສະເຫຼີມສະຫຼອງໃນທຸກໂອກາດ.<br/><br/>"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_empowerment
msgid ""
"<i class=\"fa fa-fw fa-info-circle o_not-animable\" role=\"img\"/>  Fresh "
"and beautiful"
msgstr ""
"<i class=\"fa fa-fw fa-info-circle o_not-animable\" role=\"img\"/>  ສົດໃໝ່ ແລະ "
"ສວຍງາມ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_image_title
msgid "A Deep Dive into Blooms and Beauty"
msgstr "ເຈາະເລິກໂລກແຫ່ງດອກໄມ້ ແລະ ຄວາມງາມ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_images
msgid ""
"A delicate blend of soft pink roses and baby's breath, perfect for "
"expressing love and gratitude."
msgstr ""
"ການປະສົມປະສານທີ່ອ່ອນໂຍນຂອງດອກກຸຫຼາບສີບົວ ແລະ ດອກເບບີ້ເບຣດ (baby's breath), ເໝາະສຳລັບການສ"
"ະແດງຄວາມຮັກ ແລະ ຄວາມຂອບໃຈ."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_image_hexagonal
msgid "A place of paradise for flower lovers"
msgstr "ສະຫວັນສຳລັບຄົນຮັກດອກໄມ້"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_quotes_carousel
msgid ""
"A small shop with a very large selection of roses. Nice prices and above all"
" a very professional and friendly welcome."
msgstr ""
"ຮ້ານນ້ອຍໆທີ່ມີດອກກຸຫຼາບໃຫ້ເລືອກຫຼາກຫຼາຍ. ລາຄາເປັນກັນເອງ ແລະ ທີ່ສຳຄັນແມ່ນການຕ້ອນຮັບທີ່ເປັນມືອາຊີບ ແລະ "
"ອົບອຸ່ນ."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_quotes_carousel
msgid ""
"A wide range of high quality products and a warm welcome! I recommend this "
"shop 200%!"
msgstr ""
"ມີສິນຄ້າຄຸນນະພາບສູງຫຼາກຫຼາຍຢ່າງ ແລະ ການຕ້ອນຮັບທີ່ດີເລີດ! ຂ້ອຍຂໍແນະນຳຮ້ານນີ້ 200% ເລີຍ!"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_framed_intro
msgid "About Us"
msgstr "ກ່ຽວກັບພວກເຮົາ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_company_team_basic
msgid "Aline Turner, Bouquet Designer"
msgstr "Aline Turner, ນັກອອກແບບຊໍ່ດອກໄມ້"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_company_team_basic
msgid "Aline is the mastermind behind our bespoke floral arrangements."
msgstr ""
"Aline ແມ່ນຜູ້ນຳພາໃນການສ້າງສັນການຈັດດອກໄມ້ຕາມສັ່ງທີ່ເປັນເອກະລັກຂອງພວກເຮົາ."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_three_columns
msgid ""
"As we use local growers, our flowers last longer and smell better. Just like"
" the event you want to celebrate with flowers!"
msgstr ""
"ເນື່ອງຈາກພວກເຮົາໃຊ້ດອກໄມ້ຈາກຊາວກະສິກອນພາຍໃນທ້ອງຖິ່ນ, ດອກໄມ້ຂອງພວກເຮົາຈຶ່ງສົດໄດ້ດົນກວ່າ ແລະ ມີກິ່ນ"
"ຫອມກວ່າ. ເໝາະສຳລັບທຸກງານທີ່ທ່ານຕ້ອງການສະເຫຼີມສະຫຼອງດ້ວຍດອກໄມ້!"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_three_columns
msgid "Bio Flowers"
msgstr "ດອກໄມ້ຊີວະພາບ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_unveil
msgid "Bloom with Elegance"
msgstr "ເບີກບານດ້ວຍຄວາມສະຫງ່າງາມ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.configurator_s_kickoff
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_framed_intro
msgid "Bloom with Joy:"
msgstr "ເບີກບານດ້ວຍຄວາມສຸກ:"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_cards_grid
msgid "Blooming with Quality and Care"
msgstr "ເບີກບານດ້ວຍຄຸນນະພາບ ແລະ ຄວາມໃສ່ໃຈ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_carousel_intro
msgid "Blooming with elegance and beauty"
msgstr "ເບີກບານດ້ວຍຄວາມສະຫງ່າງາມ ແລະ ຄວາມສວຍງາມ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_images
msgid "Blushing Harmony"
msgstr "ຄວາມກົມກຽວແຫ່ງສີບົວ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.configurator_s_image_text_overlap
msgid ""
"Brighten any corner of the globe with our express 24-hour worldwide flower "
"delivery service."
msgstr ""
"ສ້າງຄວາມສົດໃສໃຫ້ທຸກມຸມໂລກ ດ້ວຍບໍລິການຈັດສົ່ງດອກໄມ້ດ່ວນທົ່ວໂລກພາຍໃນ 24 ຊົ່ວໂມງຂອງພວກເຮົາ."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_empowerment
msgid "Brighten your day with<br/>stunning designs from your local florist"
msgstr ""
"ສ້າງຄວາມສົດໃສໃຫ້ວັນຂອງທ່ານດ້ວຍ<br/>ການອອກແບບທີ່ສວຍງາມຈາກຮ້ານດອກໄມ້ໃນທ້ອງຖິ່ນຂອງທ່ານ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_striped_center_top
msgid "Bring Nature to Your Space"
msgstr "ນຳທຳມະຊາດມາສູ່ພື້ນທີ່ຂອງທ່ານ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_quadrant
msgid ""
"Bring nature’s beauty into your life with our exquisite floral arrangements "
"and garden designs. Our selections are perfect for any occasion and "
"setting.<br/><br/> Discover the elegance of flowers and greenery."
msgstr ""
"ນຳຄວາມງາມຂອງທຳມະຊາດມາສູ່ຊີວິດຂອງທ່ານ ດ້ວຍການຈັດດອກໄມ້ທີ່ປານີດ ແລະ ການອອກແບບສວນ. ສິ່ງທີ່ພວກເຮົ"
"າຄັດສັນມານັ້ນເໝາະສຳລັບທຸກໂອກາດ ແລະ ທຸກສະຖານທີ່.<br/><br/> ຄົ້ນພົບຄວາມສະຫງ່າງາມຂອງດອກໄມ້ ແລ"
"ະ ພື້ນທີ່ສີຂຽວ."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_card_offset
msgid "Bringing Nature to Your Doorstep"
msgstr "ສົ່ງມອບທຳມະຊາດເຖິງໜ້າບ້ານທ່ານ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_freegrid
msgid "Bringing the Beauty of Nature to Your Space"
msgstr "ນຳຄວາມງາມຂອງທຳມະຊາດມາສູ່ພື້ນທີ່ຂອງທ່ານ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_quadrant
msgid "Browse Flowers"
msgstr "ເລືອກເບິ່ງດອກໄມ້"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_empowerment
msgid ""
"Browse our floral arrangements   <i class=\"fa fa-long-arrow-right\" "
"role=\"img\"/>"
msgstr ""
"ເລືອກເບິ່ງການຈັດດອກໄມ້ຂອງພວກເຮົາ   <i class=\"fa fa-long-arrow-right\" "
"role=\"img\"/>"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_card_offset
msgid "Celebrate nature’s beauty with us."
msgstr "ຮ່ວມສະເຫຼີມສະຫຼອງຄວາມງາມຂອງທຳມະຊາດໄປກັບພວກເຮົາ."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_images
msgid "Celebrate with Our Best-Selling Bouquets, perfect for every occasion."
msgstr "ສະເຫຼີມສະຫຼອງດ້ວຍຊໍ່ດອກໄມ້ທີ່ຂາຍດີທີ່ສຸດຂອງພວກເຮົາ, ເໝາະສຳລັບທຸກໂອກາດ."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_pricelist_boxed
msgid "Classic Rose Bouquet"
msgstr "ຊໍ່ດອກກຸຫຼາບຄລາສສິກ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_pricelist_boxed
msgid ""
"Comprehensive floral decoration service for events including weddings, "
"parties, and corporate gatherings, designed to enhance your venue."
msgstr ""
"ບໍລິການຕົບແຕ່ງດອກໄມ້ແບບຄົບວົງຈອນສຳລັບງານຕ່າງໆ ເຊັ່ນ: ງານແຕ່ງດອງ, ງານລ້ຽງ, ແລະ ງານສັງສັນຂອງອົງ"
"ກອນ, ອອກແບບມາເພື່ອເພີ່ມຄວາມສວຍງາມໃຫ້ກັບສະຖານທີ່ຂອງທ່ານ."

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_striped_center_top
msgid "Crafted with nature’s finest"
msgstr "ສ້າງສັນດ້ວຍສິ່ງທີ່ດີທີ່ສຸດຈາກທຳມະຊາດ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_cards_grid
msgid "Creativity Like a Wildflower"
msgstr "ຄວາມຄິດສ້າງສັນຄືກັບດອກໄມ້ປ່າ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_benefits
msgid "Custom Floral Arrangements"
msgstr "ການຈັດດອກໄມ້ແບບພິເສດຕາມສັ່ງ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_pricelist_boxed
msgid "Custom Floral Design"
msgstr "ການອອກແບບດອກໄມ້ຕາມຄວາມຕ້ອງການ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_wavy_grid
msgid "Customized Bouquets"
msgstr "ຊໍ່ດອກໄມ້ທີ່ອອກແບບສະເພາະ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_benefits
msgid "Dedicated Service"
msgstr "ການບໍລິການດ້ວຍຄວາມຈິງໃຈ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_images_mosaic
msgid "Discover Our Latest Floral Arrangements"
msgstr "ຄົ້ນພົບການຈັດດອກໄມ້ແບບໃໝ່ລ້າສຸດຂອງພວກເຮົາ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_key_images
msgid "Discover Our Most Loved Arrangements"
msgstr "ຄົ້ນພົບການຈັດດອກໄມ້ທີ່ເປັນທີ່ນິຍົມທີ່ສຸດຂອງພວກເຮົາ"

#. module: theme_orchid
#: model_terms:theme.ir.ui.view,arch:theme_orchid.s_shape_image
msgid ""
"Discover our exquisite floral arrangements for any occasion. From vibrant "
