<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_image_text" inherit_id="website.s_image_text">
        <!-- Section -->
        <xpath expr="//section" position="attributes">
            <attribute name="class" add="o_cc o_cc2 pt184 pb64" remove="pt32 pb32" separator=" "/>
            <attribute name="data-oe-shape-data">{"shape":"web_editor/Origins/08","flip":[]}</attribute>
        </xpath>
        <!-- Shape -->
        <xpath expr="//div[hasclass('container')]" position="before">
            <div class="o_we_shape o_web_editor_Origins_08"/>
        </xpath>       
        <!-- Column #1 -->
        <xpath expr="//div[hasclass('col-lg-6')]" position="attributes">
            <attribute name="class" add="col-lg-8" remove="col-lg-6" separator=" "/>
        </xpath>
        <!-- Column #2 -->
        <xpath expr="//div[hasclass('col-lg-6')]" position="replace">
            <div class="pt16 pb16 col-lg-4">
                <h2>
                    <span style="font-size: 48px;">Our vision</span>
                </h2>
                <p><br/>We see our role as that of a legal partner responsible for constantly finding practical and pragmatic solutions that are adapted to our clients' needs.</p>
                <p><a href="#0" class="btn btn-primary flat">Discover more</a></p>
            </div>
        </xpath>
        <!-- Image -->
        <xpath expr="//img" position="attributes">
            <attribute name="class" add="padding-xl" separator=" "/>
            <!-- Enable SVG dynamic color functionality -->
            <attribute name="src">/web_editor/shape/theme_odoo_experts/s_image_text.svg?c1=%23278F84</attribute>
        </xpath>
    </template>
</odoo>
