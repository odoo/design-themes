<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_product_list" inherit_id="website.s_product_list">
    <!-- Container -->
    <xpath expr="//div[hasclass('container')]" position="replace">
        <div class="container">
            <!-- Row #1 -->
            <div class="row">
                <!-- Item #1 -->
                <div class="h-100 pb40 col-lg-4">
                    <a href="#">
                        <img src="/web/image/website.s_product_list_default_image_1" alt="" class="img img-fluid w-100 rounded" style="max-height: 100%;"/>
                    </a>
                    <div class="position-relative">
                        <a href="#" class="btn btn-primary position-absolute top-100 start-50 translate-middle w-75">Social Strategy</a>
                    </div>
                </div>
                <!-- Item #2 -->
