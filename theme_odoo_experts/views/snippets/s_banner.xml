<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_banner" inherit_id="website.s_banner">
        <!-- Section -->
        <xpath expr="//section" position="attributes">
            <attribute name="class" add="o_full_screen_height o_cc5 o_background_video s_parallax_no_overflow_hidden" remove="parallax s_parallax_is_fixed" separator=" "/>
            <attribute name="data-scroll-background-ratio">0</attribute>
            <attribute name="data-oe-shape-data">{"shape":"web_editor/Origins/02_001","flip":[]}</attribute>
            <attribute name="data-bg-video-src">//player.vimeo.com/video/372182235?autoplay=1&amp;muted=1&amp;loop=1</attribute>
        </xpath>
        <!-- Video, filter & shape -->
        <xpath expr="//div[hasclass('container')]" position="before">
            <div class="o_we_bg_filter" style="background-color: rgba(73, 64, 72, 0.75) !important;"/>
            <div class="o_we_shape o_web_editor_Origins_02_001"/>
        </xpath>
        <!-- Container -->
        <xpath expr="//div[hasclass('container')]" position="attributes">
            <attribute name="class" add="o_container_small" remove="container" separator=" "/>
        </xpath>
        <!-- Jumbotron -->
        <xpath expr="//div[hasclass('jumbotron')]" position="attributes">
            <attribute name="class" add="col-lg-12" remove="col-lg-6 rounded o_cc1" separator=" "/>
            <attribute name="style">text-align: center;</attribute>
        </xpath>
        <!-- Title -->
        <xpath expr="//h1" position="replace">
            <h1 style="text-align: center;">
                <span style="font-size: 62px;">We care <br/>about results</span>
            </h1>
        </xpath>
        <!-- Paragraphs -->
        <xpath expr="//p" position="replace">
            <p><br/></p>
            <p class="lead" style="text-align: center;">Guided by expertise gained over 20 years of achieving success for clients, we practice with passion and strategic focus on the future.</p>
        </xpath>
        <!-- Button -->
        <xpath expr="//t[@t-esc='cta_btn_text']" position="replace">
            <t t-esc="cta_btn_text">Discover More</t>
        </xpath>
    </template>
</odoo>
