<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_three_columns" inherit_id="website.s_three_columns">
        <!-- Section -->
        <xpath expr="//section" position="attributes">
            <attribute name="class" add="pt72 pb72 o_colored_level" remove="pt32 pb32" separator=" "/>
            <attribute name="data-oe-shape-data">{"shape":"web_editor/Floats/04","flip":[]}</attribute>
        </xpath>
        <!-- Shape -->
        <xpath expr="//div[hasclass('container')]" position="before">
            <div class="o_we_shape o_web_editor_Floats_04"/>
        </xpath>
        <!-- Card #1 -->
        <xpath expr="//div[hasclass('card')]" position="attributes">
            <attribute name="style">border-width: 0px !important; box-shadow: rgba(0, 0, 0, 0.05) 0px 8px 16px 0px !important;</attribute>
        </xpath>
        <!-- Card #1 - Title -->
        <xpath expr="//h3" position="replace">
            <h3 class="card-title">Data Insights</h3>
        </xpath>
        <!-- Card #2 -->
        <xpath expr="(//div[hasclass('card')])[2]" position="attributes">
            <attribute name="style">border-width: 0px !important; box-shadow: rgba(0, 0, 0, 0.05) 0px 8px 16px 0px !important;</attribute>
        </xpath>
        <!-- Card #2 - Title -->
        <xpath expr="(//h3)[2]" position="replace">
            <h3 class="card-title">Strategies</h3>
        </xpath>
        <!-- Card #3 -->
        <xpath expr="(//div[hasclass('card')])[3]" position="attributes">
            <attribute name="style">border-width: 0px !important; box-shadow: rgba(0, 0, 0, 0.05) 0px 8px 16px 0px !important;</attribute>
        </xpath>
        <!-- Card #3 - Title -->
        <xpath expr="(//h3)[3]" position="replace">
            <h3 class="card-title">Optimization</h3>
        </xpath>
    </template>
</odoo>
