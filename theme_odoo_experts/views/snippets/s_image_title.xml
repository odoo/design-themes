<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_image_title" inherit_id="website.s_image_title">
    <xpath expr="//section" position="attributes">
        <attribute name="class" add="o_cc1" remove="o_cc5 oe_img_bg" separator=" "/>
        <attribute name="style"/>
        <attribute name="data-oe-shape-data">{'shape':'html_builder/Blurry/06','flip':[]}</attribute>
    </xpath>
    <xpath expr="//div[hasclass('o_we_bg_filter')]" position="replace"/>

    <!-- Shape -->
    <xpath expr="//div[hasclass('container')]" position="before">
        <div class="o_we_shape o_html_builder_Blurry_06"/>
    </xpath>
</template>

</odoo>
