<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ======== COLLECTION BANNER ======== -->
<template id="s_banner_product" inherit_id="website.s_banner_product">
    <xpath expr="//div[hasclass('o_we_bg_filter')]" position="attributes">
        <attribute name="class" remove="bg-black-25" separator=" "/>
        <attribute name="style">background-image: linear-gradient(rgba(0, 0, 0, 0.15) 50%, rgba(0, 0, 0, 0.5) 85%);</attribute>
    </xpath>
    <xpath expr="//div[hasclass('o_grid_item')]" position="attributes">
        <attribute name="class">o_grid_item g-col-lg-4 col-lg-4 g-height-3</attribute>
        <attribute name="style">grid-area: 12 / 1 / 15 / 5; --grid-item-padding-y: 32px; --grid-item-padding-x: 32px; z-index: 2;</attribute>
    </xpath>
    <xpath expr="//p" position="attributes">
        <attribute name="class" add="lead" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('o_grid_item')][2]" position="attributes">
        <attribute name="style" remove="z-index: 2;" add="z-index: 3;" separator=";"/>
    </xpath>
    <!-- Add extra grid item and move the title inside it -->
    <xpath expr="//div[hasclass('o_grid_item')]" position="before">
        <div class="o_grid_item g-col-lg-6 g-height-5 col-lg-6" style="--grid-item-padding-x: 32px; --grid-item-padding-y: 32px; z-index: 1; grid-area: 1 / 1 / 6 / 7;"/>
    </xpath>
    <xpath expr="//div[hasclass('o_grid_item')]" position="inside">
        <xpath expr="//h2" position="move"/>
    </xpath>
    <xpath expr="//h2" position="attributes">
        <attribute name="class" add="display-3-fs" separator=" "/>
    </xpath>
</template>

<!-- ======== TITLE ======== -->
<template id="s_title" inherit_id="website.s_title">
    <xpath expr="//h2" position="attributes">
        <attribute name="class" remove="display-3-fs" separator=" "/>
    </xpath>
</template>

<!-- ======== CATEGORIES GRID ======== -->
<template id="s_ecomm_categories_showcase" inherit_id="website.s_ecomm_categories_showcase">
    <xpath expr="//section" position="attributes">
        <attribute name="class" remove="first-large-layout" add="equal-layout" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('container')]" position="attributes">
        <attribute name="class" remove="container" add="container-fluid" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('s_ecomm_categories_showcase_block')]" position="attributes">
        <attribute name="class" remove="rounded-2" add="rounded-0" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('s_ecomm_categories_showcase_content')]//h2" position="attributes">
        <attribute name="class" add="h4-fs" remove="h3-fs" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('s_ecomm_categories_showcase_block')][2]" position="attributes">
        <attribute name="class" remove="rounded-2" add="rounded-0" separator=" "/>
    </xpath>
    <xpath expr="(//div[hasclass('s_ecomm_categories_showcase_content')])[2]//h2" position="attributes">
        <attribute name="class" add="h4-fs" remove="h3-fs" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('s_ecomm_categories_showcase_block')][3]" position="attributes">
        <attribute name="class" remove="rounded-2" add="rounded-0" separator=" "/>
    </xpath>
    <xpath expr="(//div[hasclass('s_ecomm_categories_showcase_content')])[3]//h2" position="attributes">
        <attribute name="class" add="h4-fs" remove="h3-fs" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('s_ecomm_categories_showcase_block')][4]" position="attributes">
        <attribute name="class" remove="rounded-2" add="rounded-0" separator=" "/>
    </xpath>
    <xpath expr="(//div[hasclass('s_ecomm_categories_showcase_content')])[4]//h2" position="attributes">
        <attribute name="class" add="h4-fs" remove="h3-fs" separator=" "/>
    </xpath>
</template>

<!-- ======== MASONRY BLOCK ======== -->
<template id="s_masonry_block" inherit_id="website.s_masonry_block">
    <xpath expr="//section" position="attributes">
        <attribute name="class" remove="pt48 pb48" add="pt32 pb32" separator=" "/>
    </xpath>
</template>

<!-- ======== MASONRY BLOCK - IMAGES TEMPLATE ======== -->
<template id="s_masonry_block_images_template" inherit_id="website.s_masonry_block_images_template">
    <!-- Layout -->
    <xpath expr="//t[@t-snippet-call='website.s_masonry_block']" position="attributes">
        <attribute name="container_class.f">container-fluid</attribute>
    </xpath>
    <xpath expr="//div[hasclass('o_grid_mode')]" position="attributes">
        <attribute name="style">gap: 30px;</attribute>
    </xpath>
    <xpath expr="//div[hasclass('o_grid_item')]" position="attributes">
        <attribute name="class" remove="justify-content-start rounded-3" add="justify-content-end" separator=" "/>
        <attribute name="style" remove="--grid-item-padding-y: 30px; --grid-item-padding-x: 30px;" add="--grid-item-padding-y: 32px; --grid-item-padding-x: 32px;" separator=";"/>
    </xpath>
    <xpath expr="//div[hasclass('o_grid_item')]//h2" position="attributes">
        <attribute name="style" add="text-align: end" separator=";"/>
    </xpath>
    <xpath expr="//div[hasclass('o_grid_item')][2]" position="attributes">
        <attribute name="class" remove="rounded-3" separator=" "/>
        <attribute name="style" remove="--grid-item-padding-y: 30px; --grid-item-padding-x: 30px;" add="--grid-item-padding-y: 32px; --grid-item-padding-x: 32px;" separator=";"/>
    </xpath>
    <xpath expr="//p[hasclass('lead')]" position="replace"/>
    <xpath expr="//p[hasclass('lead')]" position="replace"/>
</template>

<!-- ======== IMAGE TITLE ======== -->
<template id="s_image_title" inherit_id="website.s_image_title">
    <xpath expr="//section" position="attributes">
        <attribute name="class" add="o_full_screen_height" separator=" "/>
    </xpath>
    <xpath expr="//h1" position="attributes">
        <attribute name="class" remove="display-3" add="h3-fs" separator=" "/>
        <attribute name="style" separator=";">text-align: center;</attribute>
    </xpath>
    <xpath expr="//div[hasclass('o_we_bg_filter')]" position="attributes">
        <attribute name="class" add="bg-black-25" remove="bg-black-50" separator=" "/>
    </xpath>
</template>

<!-- ======== ANNOUNCEMENT SCROLL ======== -->
<template id="s_announcement_scroll" inherit_id="website.s_announcement_scroll">
    <xpath expr="//section" position="attributes">
        <attribute name="class" remove="s_announcement_scroll_parallax" separator=" "/>
        <attribute name="style" remove="--marquee-item-font-size: 80" add="--marquee-item-font-size: 96" separator=";"/>
    </xpath>
</template>

<!-- ======== REFERENCES LITE ======== -->
<template id="s_references_lite" inherit_id="website.s_references_lite">
    <xpath expr="//div[hasclass('container')]" position="attributes">
        <attribute name="class" add="container-fluid" remove="container" separator=" "/>
    </xpath>
</template>

</odoo>
