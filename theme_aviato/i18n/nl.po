#. module: theme_aviato
#: model_terms:theme.ir.ui.view,arch:theme_aviato.s_showcase
msgid ""
"From booking to departure, we handle all the details so you can focus on "
"enjoying your adventure."
msgstr ""
"Van boeking tot vertrek, wij regelen alle details zodat jij je kunt richten "
"op het genieten van je avontuur."

#. module: theme_aviato
#: model_terms:theme.ir.ui.view,arch:theme_aviato.s_masonry_block_default_template
msgid "Greece"
msgstr "Griekenland"

#. module: theme_aviato
#: model:ir.model.fields,field_description:theme_aviato.field_theme_utils__id
