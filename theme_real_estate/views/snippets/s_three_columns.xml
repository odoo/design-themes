<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_three_columns" inherit_id="website.s_three_columns">
        <!-- Section -->
        <xpath expr="//section" position="attributes">
            <attribute name="class" add="o_cc o_cc3" remove="bg-200" separator=" "/>
            <attribute name="class" add="pt0 pb72" remove="pt32 pb32" separator=" "/>

        </xpath>
        <!-- Column 1 -->
        <xpath expr="//div[hasclass('card-body')]" position="replace">
            <div class="card-body">
                <span class="card-text lead font-weight-bold d-inline-block mb-2">$295,000</span>
                <h3 class="card-title">House On The Hill</h3>
                <p class="card-text mb-4"> Waste no time in viewing this truly stunning property. The property's surroundings really set it apart, offering idyllic sea views overlooking a park. </p>
                <a href="#" class="btn btn-secondary btn-block mb-0">View details</a>
            </div>
        </xpath>
        <!-- Column 2 -->
        <xpath expr="(//div[hasclass('card-body')])[2]" position="replace">
            <div class="card-body">
                <span class="card-text lead font-weight-bold d-inline-block mb-2">$1,295,000,000</span>
                <h3 class="card-title">Moutain View</h3>
                <p class="card-text mb-4">The house is surrounded by garden terraces that create unique spaces and an intimate ambience. With no overlooking neighbours, the garden offers real privacy.</p>
                <a href="#" class="btn btn-secondary btn-block mb-0">View details</a>
            </div>
        </xpath>
        <!-- Column 3 -->
        <xpath expr="(//div[hasclass('card-body')])[3]" position="replace">
            <div class="card-body">
                <span class="card-text lead font-weight-bold d-inline-block mb-2">$455,000</span>
                <h3 class="card-title">Paradise Residence</h3>
                <p class="card-text mb-4">Elegant, modern sophisticated architecture with an impressive in large scale home designed with the finest imported finishes. Pyrgon, marble and wood floors...</p>
                <a href="#" class="btn btn-secondary btn-block mb-0">View details</a>
            </div>
        </xpath>
    </template>
</odoo>
