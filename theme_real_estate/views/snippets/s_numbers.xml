<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_numbers" inherit_id="website.s_numbers">
        <!-- Section -->
        <xpath expr="//section" position="attributes">
            <attribute name="class" add="o_cc o_cc1" remove="o_cc o_cc2" separator=" "/>
                        <attribute name="class" add="pt32 pb56" remove="pt24 pb24" separator=" "/>

        </xpath>
        <!-- Column #01 -->
        <xpath expr="//div[hasclass('col-lg-3')][1]/h6" position="replace">
            <h6 class="text-muted">properties already sold</h6>
        </xpath>
        <xpath expr="//div[hasclass('col-lg-3')][1]/span" position="replace">
            <span class="s_number" style="font-size:36px;">14,000</span>
        </xpath>
        <!-- Column #02 -->
        <xpath expr="//div[hasclass('col-lg-3')][2]/span" position="replace">
            <span class="s_number" style="font-size:36px;">97%</span>
        </xpath>
        <xpath expr="//div[hasclass('col-lg-3')][2]/h6" position="replace">
            <h6 class="text-muted">happy customers</h6>
        </xpath>
        <!-- Column #03 -->
        <xpath expr="//div[hasclass('col-lg-3')][3]/span" position="replace">
            <span class="s_number" style="font-size:36px;">142</span>
        </xpath>
        <xpath expr="//div[hasclass('col-lg-3')][3]/h6" position="replace">
            <h6 class="text-muted">amazing agents</h6>
        </xpath>
        <!-- Column #04 -->
        <xpath expr="//div[hasclass('col-lg-3')][4]/span" position="replace">
            <span class="s_number" style="font-size:36px;">100+</span>
        </xpath>
        <xpath expr="//div[hasclass('col-lg-3')][4]/h6" position="replace">
            <h6 class="text-muted">offices</h6>
        </xpath>
    </template>
</odoo>
