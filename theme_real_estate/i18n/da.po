#. module: theme_real_estate
#: model_terms:theme.ir.ui.view,arch:theme_real_estate.s_banner
msgid "<b>Real Estate Agency.<br/>Near You.</b>"
msgstr "<b>Ejendomsmægler.<br/>I nærheden af dig.</b>"

#. module: theme_real_estate
#: model_terms:theme.ir.ui.view,arch:theme_real_estate.s_empowerment
msgid ""
"<br/>Connecting you with the perfect property through personalized guidance."
"<br/><br/>"
msgstr ""
"<br/>Vi hjælper dig med at finde den perfekte bolig gennem personlig "
"rådgivning.<br/><br/>"

#. module: theme_real_estate
#: model_terms:theme.ir.ui.view,arch:theme_real_estate.s_split_intro
msgid ""
"<br/>Discover your ideal home with our expert real estate services. We guide "
"you through every step of the buying or selling process, offering "
"personalized support and in-depth market knowledge. Whether you're searching "
"for a new house or an investment property, we're here to help you make "
"informed decisions and find a space you'll love.<br/><br/>"
msgstr ""
"<br/>Find dit drømmehjem med vores professionelle ejendomsservice. Vi følger "
"dig gennem hvert trin i købs- eller salgsprocessen og tilbyder personlig "
"rådgivning samt indgående markedskendskab. Uanset om du er på udkig efter et "
"nyt hus eller en investeringsejendom, hjælper vi dig med at træffe "
"velovervejede beslutninger og finde et hjem, der falder i din smag.<br/><br/>"

#. module: theme_real_estate
#: model_terms:theme.ir.ui.view,arch:theme_real_estate.s_cover
msgid ""
"<font class=\"text-o-color-2\">ESTATE ®</font><br/>Your easy home search, "
"all in one"
msgstr ""
"<font class=\"text-o-color-2\">ESTATE ®</font><br/>Din nemme boligsøgning, "
"alt på ét sted"

#. module: theme_real_estate
#: model_terms:theme.ir.ui.view,arch:theme_real_estate.s_striped_top
