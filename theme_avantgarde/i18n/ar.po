#. module: theme_avantgarde
#: model_terms:theme.ir.ui.view,arch:theme_avantgarde.s_features_wall
msgid "For all the family"
msgstr "لكافة أفراد العائلة"

#. module: theme_avantgarde
#: model_terms:theme.ir.ui.view,arch:theme_avantgarde.s_features_wall
