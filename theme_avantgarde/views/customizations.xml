    <xpath expr="(//img)[5]" position="attributes">
        <attribute name="src">/html_editor/image_shape/website.s_company_team_image_5/html_builder/geometric_round/geo_round_gem.svg</attribute>
        <attribute name="data-shape">html_builder/geometric_round/geo_round_gem</attribute>
