#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_cover
msgid ""
"<br/>\n"
"            <a href=\"#\" class=\"btn btn-lg btn-primary "
"o_translate_inline\">Our solutions</a>"
msgstr ""
"<br/>\n"
"            <a href=\"#\" class=\"btn btn-lg btn-primary "
"o_translate_inline\">Nuestras soluciones</a>"

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_text_image
msgid ""
"<br/>Clear, consistent communication drives success. We prioritize open "
"dialogue, ensuring alignment with your goals and seamless collaboration "
"throughout every project."
msgstr ""
"<br/>Una comunicación clara y consistente es lo que lleva al éxito. Le damos "
"prioridad a un diálogo abierto para asegurarnos que nos estamos apegando a "
"sus metas y podemos colaborar sin problemas en cada proyecto."

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_cover
msgid "<br/>Offering tailored strategies to drive growth and success."
msgstr "<br/>Ofrecemos estrategias que impulsan el crecimiento y éxito."

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_image_text
msgid ""
"<br/>Our code is built for performance, scalability, and reliability. With "
"meticulous attention to detail, we create clean, maintainable, and efficient "
"solutions that power your business forward."
msgstr ""
"<br/>Nuestro código está hecho para que de buen rendimiento, sea escalable y "
"confiable. Le prestamos mucha atención a los detalles para crear soluciones "
"limpias, sostenibles y eficientes que impulsen el crecimiento de su empresa."

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_text_image
msgid "Communication is key!"
msgstr "La comunicación es la clave"

