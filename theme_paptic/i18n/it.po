#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_cover
msgid ""
"<br/>\n"
"            <a href=\"#\" class=\"btn btn-lg btn-primary "
"o_translate_inline\">Our solutions</a>"
msgstr ""
"<br/>\n"
"            <a href=\"#\" class=\"btn btn-lg btn-primary "
"o_translate_inline\">Le nostre soluzioni</a>"

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_text_image
msgid ""
"<br/>Clear, consistent communication drives success. We prioritize open "
"dialogue, ensuring alignment with your goals and seamless collaboration "
"throughout every project."
msgstr ""
"<br/>Una comunicazione chiara e coerente è alla base del successo. Diamo "
"priorità al dialogo aperto, assicurando l'allineamento con i tuoi obiettivi "
"e una collaborazione perfetta in ogni progetto."

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_cover
msgid "<br/>Offering tailored strategies to drive growth and success."
msgstr ""
"<br/>Offriamo strategie su misura per guidare la crescita e il successo."

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_image_text
msgid ""
"<br/>Our code is built for performance, scalability, and reliability. With "
"meticulous attention to detail, we create clean, maintainable, and efficient "
"solutions that power your business forward."
msgstr ""
"<br/>Il nostro codice è costruito per garantire prestazioni, scalabilità e "
"affidabilità. Con un'attenzione meticolosa per i dettagli, creiamo soluzioni "
"pulite, mantenibili ed efficienti che danno potere alla tua azienda."

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_text_image
msgid "Communication is key!"
msgstr "La comunicazione è fondamentale!"

