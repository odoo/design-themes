#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_cover
msgid ""
"<br/>\n"
"            <a href=\"#\" class=\"btn btn-lg btn-primary "
"o_translate_inline\">Our solutions</a>"
msgstr ""
"<br/>\n"
"            <a href=\"#\" class=\"btn btn-lg btn-primary "
"o_translate_inline\">Ratkaisumme</a>"

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_text_image
msgid ""
"<br/>Clear, consistent communication drives success. We prioritize open "
"dialogue, ensuring alignment with your goals and seamless collaboration "
"throughout every project."
msgstr ""
"<br/>Selkeä ja johdonmukainen viestintä edistää menestystä. Asetamme "
"etusijalle avoimen dialogin, jonka avulla varmistamme, että kaikki projektit "
"ovat linjassa tavoitteidesi kanssa ja että yhteistyö sujuu saumattomasti."

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_cover
msgid "<br/>Offering tailored strategies to drive growth and success."
msgstr ""
"<br/>Tarjoamme räätälöityjä strategioita kasvun ja menestyksen edistämiseksi."

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_image_text
msgid ""
"<br/>Our code is built for performance, scalability, and reliability. With "
"meticulous attention to detail, we create clean, maintainable, and efficient "
"solutions that power your business forward."
msgstr ""
"<br/>Koodimme on rakennettu suorituskyky, skaalautuvuus ja luotettavuus "
"mielessä. Kiinnitämme huomiota yksityiskohtiin ja luomme siistejä, "
"ylläpidettäviä ja tehokkaita ratkaisuja, jotka vievät liiketoimintaasi "
"eteenpäin."

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_text_image
msgid "Communication is key!"
msgstr "Viestintä on avainasemassa!"

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_cta_box
msgid "Contact us"
msgstr "Ota yhteyttä"

