#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_cover
msgid ""
"<br/>\n"
"            <a href=\"#\" class=\"btn btn-lg btn-primary "
"o_translate_inline\">Our solutions</a>"
msgstr ""
"<br/>\n"
"            <a href=\"#\" class=\"btn btn-lg btn-primary "
"o_translate_inline\">Nos solutions</a>"

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_text_image
msgid ""
"<br/>Clear, consistent communication drives success. We prioritize open "
"dialogue, ensuring alignment with your goals and seamless collaboration "
"throughout every project."
msgstr ""
"<br/>Une communication claire et cohérente est la clé de la réussite. Nous "
"privilégions un dialogue ouvert, garantissant l'alignement sur vos objectifs "
"et une collaboration sans faille tout au long du projet."

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_cover
msgid "<br/>Offering tailored strategies to drive growth and success."
msgstr ""
"<br/>Nous proposons des stratégies sur mesure pour stimuler la croissance et "
"la réussite."

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_image_text
msgid ""
"<br/>Our code is built for performance, scalability, and reliability. With "
"meticulous attention to detail, we create clean, maintainable, and efficient "
"solutions that power your business forward."
msgstr ""
"<br/>Notre code est conçu pour la performance, l'évolutivité et la "
"fiabilité. Avec une attention méticuleuse aux détails, nous créons des "
"solutions efficaces, faciles à maintenir et qui font avancer votre "
"entreprise."

#. module: theme_paptic
#: model_terms:theme.ir.ui.view,arch:theme_paptic.s_text_image
msgid "Communication is key!"
msgstr "La communication est primordiale !"

