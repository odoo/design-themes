<?xml version="1.0" encoding="utf-8"?>
<odoo>
   <template id="s_banner" inherit_id="website.s_banner">
      <!-- Section -->
      <xpath expr="//section" position="attributes">
         <attribute name="class" add="pb120 pt256 oe_img_bg o_bg_img_center s_parallax_no_overflow_hidden" remove="pt96 pb96 s_parallax_is_fixed" separator=" "/>
         <attribute name="data-oe-shape-data">{"shape":"web_editor/Origins/02_001","flip":[]}</attribute>
         <attribute name="data-scroll-background-ratio">0</attribute>
         <!-- Enable SVG dynamic color functionality -->
         <attribute name="style">background-image:url('/web_editor/shape/theme_buzzy/s_banner.svg?c1=%23637BBE'); background-position: 50% 37%</attribute>
      </xpath>
      <!-- Delete first span -->
      <xpath expr="//span[hasclass('s_parallax_bg')]" position="replace"/>
      <!-- Shape -->
      <xpath expr="//div[hasclass('container')]" position="before">
         <div class="o_we_shape o_web_editor_Origins_02_001"/>
      </xpath>
      <!-- Container / Row -->
      <xpath expr="//div[hasclass('container')]/div/div" position="attributes">
         <attribute name="class" add="shadow" separator=" "/>
      </xpath>
      <!-- Container / title -->
      <xpath expr="//div[hasclass('container')]//h1" position="replace">
         <h1>Great software <br/>for great people</h1>
      </xpath>
      <!-- Container / paragraph -->
      <xpath expr="//p[hasclass('lead')]" position="replace">
         <p class="lead">Every clever company deserve to work with clever tools.</p>
      </xpath>
   </template>
</odoo>
