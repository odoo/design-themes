msgstr "ຄົ້ນຫາ <br/>ຜົນງານຂອງຂ້ອຍ"

#. module: theme_artists
#: model_terms:theme.ir.ui.view,arch:theme_artists.s_cover
msgid "Emotions <br/>through the colors"
msgstr "ອາລົມຄວາມຮູ້ສຶກ <br/>ຜ່ານສີສັນ"

