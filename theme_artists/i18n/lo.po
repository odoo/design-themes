#: model_terms:theme.ir.ui.view,arch:theme_artists.s_big_number
msgid ""
"<font class=\"text-gradient\" style=\"background-image: linear-"
"gradient(0deg, var(--o-color-1) 25%, var(--o-color-4) 90%);\">\n"
"            250+\n"
"        </font>"
msgstr ""
"<font class=\"text-gradient\" style=\"background-image: linear-"
"gradient(0deg, var(--o-color-1) 25%, var(--o-color-4) 90%);\">\n"
"            250+\n"
