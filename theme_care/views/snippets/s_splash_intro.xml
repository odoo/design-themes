<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_splash_intro" inherit_id="website.s_splash_intro">
    <!-- Section -->
    <xpath expr="//section" position="attributes">
        <attribute name="class" add="o_cc o_cc5 pb64" remove="pb88" separator=" "/>
    </xpath>
    <xpath expr="//a[hasclass('o_scroll_button')]" position="replace"/>
    <xpath expr="//p[hasclass('lead')]" position="replace" mode="inner">
        <strong>Your path to recovery</strong>
    </xpath>
    <xpath expr="//h1" position="replace" mode="inner">
        Restore your movement.<br/>Reclaim your life.
    </xpath>
    <xpath expr="//a[hasclass('btn')]/t" position="replace" mode="inner">
        Book a consultation
    </xpath>
</template>

</odoo>
