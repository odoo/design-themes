"\" Their care and learning are wonderful. Safe, nurturing, and full of "
"creativity. \""
msgstr ""
"\"Deres omsorg og undervisning er fantastisk. Trygt, omsorgsfuldt og fuld af "
"kreativitet.\""

#. module: theme_kiddo
#: model_terms:theme.ir.ui.view,arch:theme_kiddo.s_call_to_action
msgid "2,000 parents<br/> brought their kid to our nursery."
msgstr "2.000 forældre<br/> har valgt vores vuggestue til deres barn."

#. module: theme_kiddo
#: model_terms:theme.ir.ui.view,arch:theme_kiddo.s_three_columns
msgid ""
"<br/>\n"
"        For every kid"
msgstr ""
"<br/>\n"
"        Til alle børn"

#. module: theme_kiddo
#: model_terms:theme.ir.ui.view,arch:theme_kiddo.s_three_columns
msgid ""
"<br/>\n"
"        Open-door policy"
msgstr ""
"<br/>\n"
"        Åben dør-politik"

#. module: theme_kiddo
#: model_terms:theme.ir.ui.view,arch:theme_kiddo.s_three_columns
msgid ""
"<br/>\n"
