#. module: theme_treehouse
#: model_terms:theme.ir.ui.view,arch:theme_treehouse.s_color_blocks_2
msgid ""
"<br/>\n"
"        Environmental protection is the practice of safeguarding the natural "
"world from harmful human activities and preserving ecosystems for future "
"generations. It involves efforts to reduce pollution, conserve biodiversity, "
"and sustainably manage natural resources such as air, water, and soil.\n"
"        <br/>"
msgstr ""
"<br/>\n"
"        Environmental protection is the practice of safeguarding the natural "
"world from harmful human activities and preserving ecosystems for future "
"generations. It involves efforts to reduce pollution, conserve biodiversity, "
"and sustainably manage natural resources such as air, water, and soil.\n"
"        <br/>"

#. module: theme_treehouse
#: model_terms:theme.ir.ui.view,arch:theme_treehouse.s_sidegrid
msgid ""
"<br/>\n"
"        Every step we take towards sustainability is a commitment to "
"preserving nature's beauty and resources, for today and tomorrow."
msgstr ""
"<br/>\n"
"        Every step we take towards sustainability is a commitment to "
"preserving nature's beauty and resources, for today and tomorrow."

#. module: theme_treehouse
#: model_terms:theme.ir.ui.view,arch:theme_treehouse.s_numbers_list
msgid ""
"<br/>\n"
"        From carbon footprint reduction to renewable energy adoption and "
"biodiversity preservation, our key milestones reflect our commitment to "
"creating a sustainable future for all."
msgstr ""
"<br/>\n"
"        From carbon footprint reduction to renewable energy adoption and "
"biodiversity preservation, our key milestones reflect our commitment to "
"creating a sustainable future for all."

#. module: theme_treehouse
#: model_terms:theme.ir.ui.view,arch:theme_treehouse.s_numbers_list
msgid ""
"<span class=\"h2-fs\">1.2 Billion</span><br/>\n"
"        Liters of water saved"
msgstr ""
"Tiết kiệm <span class=\"h2-fs\">1,2 tỷ</span><br/>\n"
"        lít nước"

#. module: theme_treehouse
#: model_terms:theme.ir.ui.view,arch:theme_treehouse.s_numbers_list
msgid ""
"<span class=\"h2-fs\">2 Million</span><br/>\n"
"        Trees Planted"
msgstr ""
"Trồng <span class=\"h2-fs\">2 triệu</span><br/>\n"
"        cây xanh"

#. module: theme_treehouse
#: model_terms:theme.ir.ui.view,arch:theme_treehouse.s_numbers_list
msgid ""
"<span class=\"h2-fs\">45%</span><br/>\n"
"        Reduction in carbon emissions"
msgstr ""
"Giảm <span class=\"h2-fs\">45%</span><br/>\n"
"        lượng phát thải carbon"

#. module: theme_treehouse
#: model_terms:theme.ir.ui.view,arch:theme_treehouse.s_numbers_list
msgid ""
"<span class=\"h2-fs\">500,000</span><br/>\n"
"        Tons of materials recycled"
msgstr ""
"Tái chế <span class=\"h2-fs\">500.000</span><br/>\n"
"        tấn vật liệu"

#. module: theme_treehouse
#: model_terms:theme.ir.ui.view,arch:theme_treehouse.s_numbers_list
msgid ""
"<span class=\"h2-fs\">60%</span><br/>\n"
"        Renewable Energy usage"
msgstr ""
"Lượng sử dụng năng lượng tái tạo\n"
"đạt <span class=\"h2-fs\">60%</span><br/>"

#. module: theme_treehouse
#: model_terms:theme.ir.ui.view,arch:theme_treehouse.s_numbers_list
msgid ""
"<span class=\"h2-fs\">85%</span><br/>\n"
"        Waste diversion rate"
msgstr ""
"Tỷ lệ chuyển hướng chất thải\n"
"đạt <span class=\"h2-fs\">85%</span><br/>"

