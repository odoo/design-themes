<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_features" inherit_id="website.s_features">
    <!-- Section -->
    <xpath expr="//section" position="attributes">
        <attribute name="class" add="pt48 pb48" remove="pt64 pb64" separator=" "/>
    </xpath>
    <!-- Icons -->
    <xpath expr="(//i)[1]" position="attributes">
        <attribute name="class" add="mb-4 rounded-circle" remove="mb-3 rounded" separator=" "/>
        <attribute name="data-icon" add="eco" remove="send" separator=" "/>
    </xpath>
    <xpath expr="(//i)[2]" position="attributes">
        <attribute name="class" add="mb-4 rounded-circle" remove="mb-3 rounded" separator=" "/>
        <attribute name="data-icon" add="flash_on" remove="credit_card" separator=" "/>
    </xpath>
    <xpath expr="(//i)[3]" position="attributes">
        <attribute name="class" add="mb-4 rounded-circle" remove="mb-3 rounded" separator=" "/>
        <attribute name="data-icon" add="water_drop" remove="flag" separator=" "/>
    </xpath>
</template>

</odoo>
