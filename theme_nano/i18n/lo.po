#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_parallax
msgid ""
"<font class=\"bg-o-color-5\">Feel free to come up with your big idea. <br/> "
"We take care of the rest.</font>"
msgstr ""

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.new_page_template_about_map_s_text_block_h1
msgid "About Us"
msgstr "ກ່ຽວກັບພວກເຮົາ"

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_features
msgid "Adaptable"
msgstr "ປັບຕົວໄດ້ງ່າຍ"

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_cover
msgid "Creative Studio"
msgstr "ສະຕູດິໂອສ້າງສັນ"

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_three_columns
msgid "Details"
msgstr "ລາຍລະອຽດ"

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_features
msgid "Durable"
msgstr "ທົນທານ"

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_three_columns
msgid "Handcrafted"
msgstr "ເຮັດດ້ວຍມື (Handcrafted)"

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_three_columns
msgid "Innovative"
msgstr "ເຕັມໄປດ້ວຍນະວັດຕະກໍາ"

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_features
msgid "Intuitive"
msgstr "ໃຊ້ງານງ່າຍ"

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_three_columns
msgid "Made in Santa's Workshop. High quality fabric &amp; exclusive designs."
msgstr "ຜະລິດຈາກໂຮງງານຂອງ Santa. ຜ້າຄຸນນະພາບສູງ ແລະ ການອອກແບບທີ່ພິເສດສະເພາະ."

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_three_columns
msgid ""
"People should love the things they own. Things should be built to last."
msgstr ""
"ຜູ້ຄົນຄວນຈະຮັກໃນສິ່ງທີ່ເຂົາເຈົ້າເປັນເຈົ້າຂອງ. ແລະ ສິ່ງຂອງເຫຼົ່ານັ້ນກໍຄວນຈະຖືກສ້າງມາເພື່ອໃຫ້ໃຊ້ງານໄດ້ຍາວນາ"
"ນ."

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_three_columns
msgid "Tailored"
msgstr "ປັບແຕ່ງສະເພາະ"

#. module: theme_nano
#: model:ir.model,name:theme_nano.model_theme_utils
msgid "Theme Utils"
msgstr "ເຄື່ອງມືຊ່ວຍຈັດການທີມ (Theme Utils)"

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_three_columns
msgid "Transforming traditional crafts — with a shot of modern savvy!"
msgstr "ປ່ຽນແປງຝີມືແບບດັ້ງເດີມ — ດ້ວຍຄວາມຊ່ຽວຊານໃນຍຸກສະໄໝໃໝ່!"

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_features
msgid "We build modular solutions."
msgstr "ພວກເຮົາສ້າງທາງອອກແບບໂມດູລາ."

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_cover
msgid ""
"We combine smart design with rich technology <br/>to craft innovative "
"products."
msgstr ""
"ພວກເຮົາປະສົມປະສານການອອກແບບທີ່ສະຫຼາດ ກັບເຕັກໂນໂລຊີທີ່ທັນສະໄໝ <br/>ເພື່ອສ້າງຜະລິດຕະພັນທີ່ມີນະວັດຕະກໍ"
"າ."

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_features
msgid "We craft long-lasting goods."
msgstr "ພວກເຮົາສ້າງສັນສິນຄ້າທີ່ໃຊ້ງານໄດ້ຍາວນານ."

#. module: theme_nano
#: model_terms:theme.ir.ui.view,arch:theme_nano.s_features
msgid "We create easy-to-use products."
msgstr "ພວກເຮົາສ້າງຜະລິດຕະພັນທີ່ໃຊ້ງານໄດ້ງ່າຍ."
