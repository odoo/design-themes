#: model_terms:theme.ir.ui.view,arch:theme_nano.s_numbers
msgid ""
"<span class=\"s_number display-1-fs\">4.5</span><br/>\n"
"                <span class=\"h5-fs\">Review Rate</span>"
msgstr ""
