msgid ""
"<font class=\"bg-o-color-5\">Feel free to come up with your big idea. <br/> "
"We take care of the rest.</font>"
msgstr ""
"<font class=\"bg-o-color-5\">Nie wahaj się przedstawić swojego pomysłu. "
"<br/> My zajmiemy się resztą.</font>"

