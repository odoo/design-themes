<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_splash_intro" inherit_id="website.s_splash_intro">
    <!-- Section -->
    <xpath expr="//section" position="attributes">
        <attribute name="class" add="o_cc o_cc5 pb64" remove="pb88" separator=" "/>
        <attribute name="data-oe-shape-data">{"shape":"html_builder/Containers/03", "colors":{"c5": "o-color-3"}}</attribute>
    </xpath>
    <xpath expr="//div[hasclass('container')]" position="before">
        <div class="o_we_shape o_html_builder_Containers_03" style="background-image: url('/html_editor/shape/html_builder/Containers/03.svg?c5=o-color-3');"/>
    </xpath>
    <xpath expr="//a[hasclass('o_scroll_button')]" position="replace"/>
    <xpath expr="//p[hasclass('lead')]" position="replace">
        <p class="lead">Spring Essentials</p>
    </xpath>
    <xpath expr="//h1" position="replace" mode="inner">
        Discover our<br/>latest collection
    </xpath>
    <xpath expr="//a[hasclass('btn')]" position="replace">
        <a t-att-href="shop_btn_href" class="o_translate_inline btn btn-lg btn-primary">Shop Now</a>
    </xpath>
</template>

</odoo>
