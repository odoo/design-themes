#. module: theme_bistro
#: model_terms:theme.ir.ui.view,arch:theme_bistro.s_text_cover
msgid "Present your<br/>menus.Easily."
msgstr "Præsenter dine<br/>menuer. Helt nemt."

#. module: theme_bistro
#: model_terms:theme.ir.ui.view,arch:theme_bistro.s_wavy_grid
msgid "Quality and Freshness"
msgstr "Kvalitet og friskhed"

#. module: theme_bistro
#: model_terms:theme.ir.ui.view,arch:theme_bistro.s_striped_center_top
msgid "Reserve Your Table"
msgstr "Reservér dit bord"

#. module: theme_bistro
#: model_terms:theme.ir.ui.view,arch:theme_bistro.s_freegrid
#: model_terms:theme.ir.ui.view,arch:theme_bistro.s_quadrant
