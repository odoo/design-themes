#: model:ir.model.fields,field_description:theme_vehicle.field_theme_utils__display_name
msgid "Display Name"
msgstr "اسم العرض"

#. module: theme_vehicle
#: model_terms:theme.ir.ui.view,arch:theme_vehicle.s_key_images
