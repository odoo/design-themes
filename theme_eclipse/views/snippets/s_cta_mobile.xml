<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_cta_mobile" inherit_id="website.s_cta_mobile">
    <!-- Section -->
    <xpath expr="//section" position="attributes">
        <attribute name="class" add="pt160 pb128" remove="pt80 pb80" separator=" "/>
    </xpath>
    <!-- Content box -->
    <xpath expr="//div[hasclass('o_grid_item')][1]" position="attributes">
        <attribute name="class" add="border" separator=" "/>
    </xpath>
    <!-- Image -->
    <xpath expr="//div[hasclass('o_grid_item_image')]" position="attributes">
        <attribute name="class" add="g-col-lg-3 col-lg-3" remove="g-col-lg-4 col-lg-4" separator=" "/>
        <attribute name="style">grid-area: 1 / 9 / 9 / 12; z-index: 2; --grid-item-padding-y: 0px; --grid-item-padding-x: 0px;</attribute>
    </xpath>
    <xpath expr="//div[hasclass('o_grid_item_image')]//img" position="attributes">
        <attribute name="src">/web/image/website.s_cta_mockups_default_image_1</attribute>
        <attribute name="class" add="img-thumbnail rounded" separator=" "/>
        <attribute name="style">padding: 8px;</attribute>
        <attribute name="data-shape"/>
        <attribute name="data-shape-colors"/>
    </xpath>
</template>

</odoo>
