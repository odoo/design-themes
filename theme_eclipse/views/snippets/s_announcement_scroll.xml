<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_announcement_scroll" inherit_id="website.s_announcement_scroll">
    <!-- Section -->
    <xpath expr="//section" position="attributes">
        <attribute name="class" add="pt72 pb88" remove="pt24 pb24" separator=" "/>
        <attribute name="style">--marquee-animation-speed: 1s; --marquee-item-font-size: 320;</attribute>
    </xpath>
</template>

</odoo>
