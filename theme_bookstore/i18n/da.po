#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_wavy_grid
msgid "Eco-Friendly Reads"
msgstr "Miljøvenlige læseoplevelser"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_pricelist_boxed
msgid "Educated"
msgstr "Uddannet"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_features_wall
msgid ""
"Enjoy a relaxing atmosphere with comfortable seating and quiet spaces "
"perfect for browsing and reading your new favorites."
msgstr ""
"Nyd den afslappede atmosfære med behagelige siddepladser og rolige rum, der "
"er perfekte til at bladre i og læse dine nye yndlingsbøger."

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_masonry_block_default_template
msgid "Enjoy your fears"
msgstr "Nyd frygten"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_key_benefits
