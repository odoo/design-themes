msgstr "Ekspertise og passion"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_numbers_showcase
msgid "Explore 12,000 unique book titles curated just for you."
msgstr "Oplev 12.000 unikke bøger, der er blevet udvalgt specielt til dig."

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_pricelist_boxed
