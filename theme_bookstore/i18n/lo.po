#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_text_image
msgid ""
"<br/>\n"
"        Discover all the publications. There is probably your next favorite book amoung them."
msgstr ""
"<br/>\n"
"        ຄົ້ນພົບສິ່ງພິມທັງໝົດ. ອາດຈະມີປຶ້ມເຫຼັ້ມຕໍ່ໄປທີ່ທ່ານມັກລວມຢູ່ໃນນັ້ນ."

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_image_text
msgid ""
"<br/>\n"
"        Discover the history of Belgium in this well-documented book with many illustrations and testimonials."
msgstr ""
"<br/>\n"
"        ຄົ້ນພົບປະຫວັດສາດຂອງປະເທດແບນຊິກໃນປຶ້ມທີ່ຮວບຮວມຂໍ້ມູນໄວ້ເປັນຢ່າງດີ ພ້ອມດ້ວຍຮູບພາບປະກອບ ແລ"
"ະ ຄຳຢືນຢັນຫຼາຍຢ່າງ."

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_three_columns
msgid "A Belgian Story"
msgstr "ເລື່ອງລາວຂອງແບນຊິກ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_numbers
msgid "Amazing pages"
msgstr "ໜ້າເວັບທີ່ໜ້າຕື່ນຕາຕື່ນໃຈ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_three_columns
msgid "At the Mars conquest"
msgstr "ການພິຊິດດາວອັງຄານ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_numbers
msgid "Beautiful snippets"
msgstr "ຊຸດຂໍ້ຄວາມທີ່ສວຍງາມ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_masonry_block_default_template
msgid "Biographies"
msgstr "ຊີວະປະຫວັດ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_call_to_action
msgid "Browse collection"
msgstr "ເລືອກເບິ່ງຄໍເລັກຊັນ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_call_to_action
msgid "Browse through <br/>our complete library"
msgstr "ເລືອກເບິ່ງ <br/>ຫ້ອງສະໝຸດທີ່ສົມບູນແບບຂອງພວກເຮົາ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_banner
msgid "Discover it <span class=\"fa fa-angle-right ms-2\"/>"
msgstr ""

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_cover
msgid "Discover more"
msgstr "ຄົ້ນຫາເພີ່ມເຕີມ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_picture
msgid "Discover our <br/>limited editions"
msgstr "ຄົ້ນພົບປຶ້ມ <br/>ສະບັບຈຳກັດ (Limited Edition)"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_three_columns
msgid ""
"Discover the history of Belgium in this well-documented book with many "
"illustrations and testimonials."
msgstr ""
"ຄົ້ນພົບປະຫວັດສາດຂອງປະເທດແບນຊິກໃນປຶ້ມທີ່ຮວບຮວມຂໍ້ມູນໄວ້ເປັນຢ່າງດີ ພ້ອມດ້ວຍຮູບພາບປະກອບ ແລະ ຄຳຢືນຢັນຫຼ"
"າຍຢ່າງ."

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_masonry_block_default_template
msgid "Discover unknown universes"
msgstr "ຄົ້ນພົບຈັກກະວານທີ່ບໍ່ເຄີຍຮູ້ຈັກ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_picture
msgid "Don't rely on a book's cover,"
msgstr "ຢ່າຕັດສິນປຶ້ມພຽງແຕ່ໜ້າປົກ,"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_masonry_block_default_template
msgid "Enjoy your fears"
msgstr "ເພີດເພີນໄປກັບຄວາມຢ້ານຂອງທ່ານ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_picture
msgid ""
"Explore our top-end Collector's Editions. <br/>Signed and limited tributes "
"to some of the most outstanding writers of all time."
msgstr ""
"ສຳຫຼວດປຶ້ມສະບັບສະສົມ (Collector's Editions) ລະດັບພຣີມ່ຽມຂອງພວກເຮົາ. <br/>ພ້ອມລາຍເຊັນ ແລ"
"ະ ຈຳນວນຈຳກັດ ເພື່ອເປັນກຽດແກ່ນັກຂຽນທີ່ໂດດເດັ່ນທີ່ສຸດຕະຫຼອດການ."

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_masonry_block_default_template
msgid "Horror"
msgstr "ສະຍອງຂວັນ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_cover
msgid "Immerse yourself <br/>in original universes"
msgstr "ດຳດິ່ງ <br/>ສູ່ຈັກກະວານແຫ່ງຕົ້ນສະບັບ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_image_text
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_three_columns
msgid ""
"Learn about the difficulties encountered by NASA engineers in sending the "
"first men to Mars."
msgstr ""
"ຮຽນຮູ້ກ່ຽວກັບຄວາມຫຍຸ້ງຍາກທີ່ວິສະວະກອນຂອງ NASA ໄດ້ພົບພໍ້ ໃນການສົ່ງມະນຸດຄົນທຳອິດໄປດາວອັງຄານ."

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_masonry_block_default_template
msgid "Meet great people"
msgstr "ພົບປະກັບຜູ້ຄົນທີ່ຍິ່ງໃຫຍ່"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_image_text
msgid "Once upon a time..."
msgstr "ກາລະຄັ້ງໜຶ່ງ..."

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_numbers
msgid "Outstanding images"
msgstr ""

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_text_image
msgid "Probably your next <br/>favorite book"
msgstr "ອາດຈະເປັນປຶ້ມ <br/>ເຫຼັ້ມຕໍ່ໄປທີ່ທ່ານມັກ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_three_columns
msgid "Re-edition"
msgstr "ສະບັບພິມຄືນໃໝ່"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_masonry_block_default_template
msgid "Read the best love stories"
msgstr "ອ່ານເລື່ອງລາວຄວາມຮັກທີ່ດີທີ່ສຸດ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_title
msgid "Reading means borrowing"
msgstr ""

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_masonry_block_default_template
msgid "Romance"
msgstr "ໂຣແມນຕິກ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_masonry_block_default_template
msgid "Science fiction"
msgstr "ວິທະຍາສາດ (Science Fiction)"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_banner
msgid "The best sellers <br/>of the year"
msgstr ""

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_three_columns
msgid ""
"The first re-edition of this Latin dictionary, from 1460. Printed originally"
" on the Gutenberg press."
msgstr ""
"ສະບັບພິມຄືນໃໝ່ຄັ້ງທຳອິດຂອງວັດຈະນານຸກົມພາສາລາຕິນນີ້, ຈາກປີ 1460. ພິມເບື້ອງຕົ້ນດ້ວຍເຄື່ອງພິມ "
"Gutenberg."

#. module: theme_bookstore
#: model:ir.model,name:theme_bookstore.model_theme_utils
msgid "Theme Utils"
msgstr "ເຄື່ອງມືຊ່ວຍເຫຼືອທີມ (Theme Utils)"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_numbers
msgid "Useful options"
msgstr "ຕົວເລືອກທີ່ມີປະໂຫຍດ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_product_list
msgid "View the book"
msgstr "ເບິ່ງປຶ້ມ"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_picture
msgid "discover more about it"
msgstr "ຄົ້ນຫາຂໍ້ມູນເພີ່ມເຕີມ"

