<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_text_image" inherit_id="website.s_text_image">
        <!-- Section -->
        <xpath expr="//section" position="attributes">
            <attribute name="class" add="o_cc o_cc5 pt112 pb112" remove="pt32 pb32" separator=" "/>
        </xpath>
        <!-- Paragraph & image -->
        <xpath expr="//div[hasclass('row')]" position="replace">
            <div class="row align-items-center">
                <div class="col-lg-5 pt16 pb16">
                    <h2>Probably your next <br/>favorite book</h2>
                    <p><br/></p>
                    <p>Discover all the publications. There is probably your next favorite book amoung them.</p>
                    <p><br/></p>
                    <p><a href="#" class="btn btn-primary mb-2">Learn more</a></p>
                </div>
                <div class="col-lg-5 offset-lg-2 pt16 pb16">
                    <img src="/web/image/website.s_text_image_default_image" class="img img-fluid mx-auto" alt=""/>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
