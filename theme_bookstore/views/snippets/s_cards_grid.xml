<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_cards_grid" inherit_id="website.s_cards_grid">
    <!-- Section  -->
    <xpath expr="//section[hasclass('s_cards_grid')]" position="attributes">
        <attribute name="class" add="o_cc1" remove="o_cc2" separator=" "/>
    </xpath>
    <!-- Title -->
    <xpath expr="//h2[hasclass('h3-fs')]" position="attributes">
        <attribute name="style">text-align: center;</attribute>
    </xpath>
    <xpath expr="//h2" position="replace" mode="inner">
        Come pay us a visit!
    </xpath>

    <!-- Card 1 -->
    <xpath expr="//div[hasclass('col-lg-6')][1]//div[hasclass('s_card')]" position="attributes">
        <attribute name="class" add="flex-lg-row-reverse border bg-100" remove="flex-lg-row" separator=" "/>
        <attribute name="style">--box-border-left-width: 0px; --box-border-bottom-width: 0px; --box-border-right-width: 0px; --box-border-top-width: 0px; --card-img-size-h: 50%;</attribute>
    </xpath>
    <xpath expr="//div[hasclass('col-lg-6')][1]//h3[hasclass('card-title')]" position="attributes">
        <attribute name="class" add="h3-fs" remove="h4-fs" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('col-lg-6')][1]//h3[hasclass('card-title')]" position="replace" mode="inner">
        Chicago
    </xpath>
    <xpath expr="//div[hasclass('col-lg-6')][1]//p[hasclass('card-text')]" position="attributes">
        <attribute name="class" add="lead" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('col-lg-6')][1]//p[hasclass('card-text')]" position="replace" mode="inner">
        55429 Issac Island
        <br/>
        Chicago, IL 60606
        <br/>
        United-States
    </xpath>
    <xpath expr="//div[hasclass('col-lg-6')][1]//p[hasclass('card-text')]" position="after">
        <p class="card-text"><a href="#top" class="o_translate_inline btn btn-primary">Get Directions</a></p>
    </xpath>
    <xpath expr="//div[hasclass('col-lg-6')][1]//div[hasclass('card-body')]" position="attributes">
        <attribute name="style">--card-spacer-x: 2rem; --card-spacer-y: 2rem;</attribute>
    </xpath>

    <!-- Card 2 -->
    <xpath expr="//div[hasclass('col-lg-6')][2]//div[hasclass('s_card')]" position="attributes">
        <attribute name="class" add="flex-lg-row-reverse border bg-100" remove="flex-lg-row" separator=" "/>
        <attribute name="style">--box-border-left-width: 0px; --box-border-bottom-width: 0px; --box-border-right-width: 0px; --box-border-top-width: 0px; --card-img-size-h: 50%;</attribute>
    </xpath>
    <xpath expr="//div[hasclass('col-lg-6')][2]//h3[hasclass('card-title')]" position="attributes">
        <attribute name="class" add="h3-fs" remove="h4-fs" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('col-lg-6')][2]//h3[hasclass('card-title')]" position="replace" mode="inner">
        San Mateo
    </xpath>
    <xpath expr="//div[hasclass('col-lg-6')][2]//p[hasclass('card-text')]" position="attributes">
        <attribute name="class" add="lead" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('col-lg-6')][2]//p[hasclass('card-text')]" position="replace" mode="inner">
        233 S Wacker Dr
        <br/>
        San Mateo, CA 94401
        <br/>
        United-States
    </xpath>
    <xpath expr="//div[hasclass('col-lg-6')][2]//p[hasclass('card-text')]" position="after">
        <p class="card-text"><a href="#top" class="o_translate_inline btn btn-primary">Get Directions</a></p>
    </xpath>
    <xpath expr="//div[hasclass('col-lg-6')][2]//div[hasclass('card-body')]" position="attributes">
        <attribute name="style">--card-spacer-x: 2rem; --card-spacer-y: 2rem;</attribute>
    </xpath>

    <xpath expr="//div[hasclass('col-lg-6')][3]" position="replace" />
    <xpath expr="//div[hasclass('col-lg-6')][3]" position="replace" />
</template>

</odoo>
