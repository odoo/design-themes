<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_features_grid" inherit_id="website.s_features_grid">
        <!-- Left Title -->
        <xpath expr="//h2" position="replace">
            <h2>Your advantages</h2>
        </xpath>
        <!-- Right Title -->
        <xpath expr="(//h2)[2]" position="replace">
            <h2>Our web store</h2>
        </xpath>
        <!-- Item #1 -->
        <xpath expr="//i" position="attributes">
            <attribute name="class" add="fa-gift bg-o-color-3 text-o-color-1" remove="fa-font-awesome bg-primary" separator=" "/>
        </xpath>
        <xpath expr="//h4" position="replace">
            <h4>Gift card</h4>
        </xpath>
        <!-- Item #2 -->
        <xpath expr="(//i)[2]" position="attributes">
            <attribute name="class" add="fa-group bg-o-color-3 text-o-color-1" remove="fa-files-o bg-primary" separator=" "/>
        </xpath>
        <xpath expr="(//h4)[2]" position="replace">
            <h4>Meet writers</h4>
        </xpath>
        <!-- Item #3 -->
        <xpath expr="(//i)[3]" position="attributes">
            <attribute name="class" add="fa-tags bg-o-color-3 text-o-color-1" remove="fa-trash bg-primary" separator=" "/>
        </xpath>
        <xpath expr="(//h4)[3]" position="replace">
            <h4>Special discounts</h4>
        </xpath>
        <!-- Item #4 -->
        <xpath expr="(//i)[4]" position="attributes">
            <attribute name="class" add="rounded-circle fa-cube bg-o-color-3 text-o-color-2" remove="rounded fa-magic bg-secondary" separator=" "/>
        </xpath>
        <xpath expr="(//h4)[4]" position="replace">
            <h4>Free returns</h4>
        </xpath>
        <!-- Item #5 -->
        <xpath expr="(//i)[5]" position="attributes">
            <attribute name="class" add="rounded-circle fa-shopping-basket bg-o-color-3 text-o-color-2" remove="rounded fa-eyedropper bg-secondary" separator=" "/>
        </xpath>
        <xpath expr="(//h4)[5]" position="replace">
            <h4>Pickup in store</h4>
        </xpath>
        <!-- Item #6 -->
        <xpath expr="(//i)[6]" position="attributes">
            <attribute name="class" add="rounded-circle fa-truck bg-o-color-3 text-o-color-2" remove="rounded fa-picture-o bg-secondary" separator=" "/>
        </xpath>
        <xpath expr="(//h4)[6]" position="replace">
            <h4>Express delivery</h4>
        </xpath>
    </template>
</odoo>
