<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_banner" inherit_id="website.s_banner">
        <!-- Section -->
        <xpath expr="//section" position="attributes">
            <attribute name="class" add="o_background_video pt240 pb24" remove="pt96 pb96 parallax s_parallax_is_fixed" separator=" "/>
            <attribute name="data-bg-video-src">//player.vimeo.com/video/435982095?autoplay=1&amp;muted=1&amp;loop=1</attribute>
            <attribute name="data-oe-shape-data">{"shape":"web_editor/Origins/04_001","flip":["y"]}</attribute>
        </xpath>
        <xpath expr="//*[hasclass('s_parallax_bg')]" position="replace"/>
        <xpath expr="//section/*" position="before">
            <div class="o_we_shape o_web_editor_Origins_04_001 o_we_flip_y"/>
        </xpath>
        <!-- Column -->
        <xpath expr="//div[hasclass('col-lg-6')]" position="attributes">
            <attribute name="class" add="col-lg-12 text-center rounded pt48 pb48" remove="col-lg-6 pt32 pb32" separator=" "/>
            <attribute name="style" add="box-shadow: rgba(0, 0, 0, 0.15) 0px 2px 4px 0px !important;"/>
        </xpath>
        <!-- Title -->
        <xpath expr="//h1" position="replace">
            <h1><b>Digital Evolution</b></h1>
        </xpath>
        <!-- Text -->
        <xpath expr="//p" position="replace">
            <p class="lead">Software Innovation as its best. Harness the power of disruptive technologies<br/> to increase your day-to-day business operations.</p>
            <p><br/></p>
        </xpath>
        <!-- Buttons -->
        <xpath expr="//t[@t-esc='cta_btn_text']" position="replace">
            <t t-esc="cta_btn_text">Our Solutions</t>
        </xpath>
        <xpath expr="//a" position="after">
            <a href="#" class="btn btn-link mb-2">Contact Us</a>
        </xpath>
    </template>
</odoo>
