msgstr "<font class=\"text-o-color-1\">ພາສາ</font>"

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_numbers
msgid "<font class=\"text-o-color-1\">Projects</font>"
msgstr ""

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_numbers
msgid "<font class=\"text-o-color-1\">Solutions</font>"
msgstr "<font class=\"text-o-color-1\">ໂຊລູຊັ່ນ</font>"

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_features
msgid "All our data centers <br/>are emission-free."
msgstr "ສູນຂໍ້ມູນທັງໝົດຂອງພວກເຮົາ <br/>ແມ່ນປອດການປ່ອຍມົນລະພິດ."

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_features
msgid "All types of files <br/>are allowed."
msgstr "ອະນຸຍາດໃຫ້ໃຊ້ <br/>ໄຟລ໌ທຸກປະເພດ."

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_three_columns
msgid "Benefits"
msgstr "ສະຫວັດດີການ"

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_color_blocks_2
msgid "Cloud <b>Solution</b>"
msgstr "<b>ໂຊລູຊັ່ນ</b> ຄລາວ"

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_features
msgid "Eco-Friendly"
msgstr "ເປັນມິດຕໍ່ສິ່ງແວດລ້ອມ"

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_three_columns
msgid "Features"
msgstr "ຄຸນສົມບັດ"

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_banner
msgid ""
"Harness the power of disruptive technologies to increase<br/> your day-to-"
"day business operations."
msgstr ""
"ນຳໃຊ້ພະລັງຂອງເຕັກໂນໂລຊີທີ່ທັນສະໄໝເພື່ອເພີ່ມ<br/> ປະສິດທິພາບໃນການດຳເນີນທຸລະກິດປະຈຳວັນຂອງທ່ານ."

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_color_blocks_2
msgid ""
"Keep your files in one place. <br/>Manage documents online with an easy to "
"use interface. <br/>Rely on an highly secure cloud storage."
msgstr ""
"ເກັບໄຟລ໌ຂອງທ່ານໄວ້ໃນບ່ອນດຽວ. <br/>ຈັດການເອກະສານອອນລາຍດ້ວຍຮູບແບບທີ່ໃຊ້ງານງ່າຍ. <br/>ໝັ້ນໃຈດ້ວ"
"ຍລະບົບເກັບຂໍ້ມູນຄລາວທີ່ມີຄວາມປອດໄພສູງ."

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_references
msgid "Our <b>References</b>"
msgstr ""

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_banner
msgid "Our Solutions"
msgstr "ໂຊລູຊັ່ນຂອງພວກເຮົາ"

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_features
msgid "Security"
msgstr "ຄວາມປອດໄພ"

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_three_columns
msgid "Services"
msgstr "ການບໍລິການ"

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_masonry_block_default_template
msgid "Super <b>Easy</b>"
msgstr "<b>ງ່າຍ</b> ຫຼາຍ"

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_masonry_block_default_template
msgid "Super <b>Fast</b>"
msgstr "<b>ໄວ</b> ຫຼາຍ"

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_features
msgid "Support"
msgstr "ຊ່ວຍເຫຼືອ"

#. module: theme_zap
#: model:ir.model,name:theme_zap.model_theme_utils
msgid "Theme Utils"
msgstr "ເຄື່ອງມືເສີມຂອງທີມ (Theme Utils)"

#. module: theme_zap
#: model_terms:theme.ir.ui.view,arch:theme_zap.s_features
msgid "We keep you safe <br/>in the cloud."
msgstr "ພວກເຮົາຮັກສາຄວາມປອດໄພໃຫ້ທ່ານ <br/>ໃນລະບົບຄລາວ."
